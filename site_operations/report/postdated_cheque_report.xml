<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_postdated_cheque" model="ir.actions.report">
        <field name="name">Post-Dated Cheque</field>
        <field name="model">x.postdated.cheque</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">site_operations.report_postdated_cheque_document</field>
        <field name="report_file">site_operations.report_postdated_cheque_document</field>
        <field name="print_report_name">'PDC - ' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_x_postdated_cheque"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_postdated_cheque_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="pdc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-3 text-center">
                            <div class="col-12">
                                <h3 style="font-weight:700;">POST-DATED CHEQUE</h3>
                                <h5 style="color:#555;">Cheque No: <t t-esc="pdc.name"/></h5>
                            </div>
                        </div>
                        <div class="border rounded p-3 mb-3" style="font-size:13px;">
                            <div class="row">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td style="width:45%;font-weight:600;">Bank</td>
                                            <td><t t-esc="pdc.bank_journal_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight:600;">Payee</td>
                                            <td><t t-esc="pdc.partner_id.name or '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight:600;">Issue Date</td>
                                            <td><t t-esc="pdc.issue_date.strftime('%d %b %Y') if pdc.issue_date else '-'"/></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td style="width:45%;font-weight:600;">Cheque Date</td>
                                            <td><t t-esc="pdc.cheque_date.strftime('%d %b %Y') if pdc.cheque_date else '-'"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight:600;">Days to Clear</td>
                                            <td><t t-esc="pdc.days_to_clearance"/> days</td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight:600;">Status</td>
                                            <td class="fw-bold" style="text-transform:capitalize;">
                                                <t t-esc="dict(pdc._fields['state'].selection).get(pdc.state, pdc.state)"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <div class="text-center mt-3 p-3 bg-light rounded">
                                <div class="text-muted small text-uppercase fw-bold">Cheque Amount</div>
                                <div class="fs-3 fw-bold">
                                    <t t-esc="pdc.currency_id.symbol"/>
                                    <t t-esc="'{:,.2f}'.format(pdc.amount)"/>
                                </div>
                            </div>
                        </div>
                        <t t-if="pdc.remarks">
                            <div class="p-3 border rounded" style="font-size:12px; color:#555;">
                                <strong>Remarks:</strong> <t t-esc="pdc.remarks"/>
                            </div>
                        </t>
                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <div style="border-top:1px solid #000;padding-top:4px;margin-top:40px;">Authorized Signatory</div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top:1px solid #000;padding-top:4px;margin-top:40px;">Finance Officer</div>
                            </div>
                        </div>
                        <p class="text-muted small mt-3">System-generated — Matracon Pakistan Pvt. Ltd.</p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
