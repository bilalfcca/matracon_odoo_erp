<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mtn_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Title -->
                        <div class="text-center mb-4">
                            <h2 class="fw-bold">MATERIAL TRANSFER NOTE</h2>
                            <h4><t t-esc="o.company_id.name"/></h4>
                        </div>

                        <!-- Reference Block -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-bordered table-sm">
                                    <tr>
                                        <th style="width:40%">MTN Reference</th>
                                        <td><t t-esc="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <th>Date</th>
                                        <td><t t-esc="o.date" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                    <tr>
                                        <th>Status</th>
                                        <td><t t-esc="o.x_site_transfer_state"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-bordered table-sm">
                                    <tr>
                                        <th style="width:40%">From Project</th>
                                        <td><t t-esc="o.x_issuance_project_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <th>To Project</th>
                                        <td><t t-esc="o.x_dest_project_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <th>From Location</th>
                                        <td><t t-esc="o.location_id.complete_name"/></td>
                                    </tr>
                                    <tr>
                                        <th>To Location</th>
                                        <td><t t-esc="o.location_dest_id.complete_name"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Materials Table -->
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr class="table-secondary">
                                    <th>#</th>
                                    <th>Product</th>
                                    <th>Description</th>
                                    <th>UoM</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Unit Cost</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.move_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line_index + 1"/></td>
                                        <td><t t-esc="line.product_id.name"/></td>
                                        <td><t t-esc="line.description_picking or ''"/></td>
                                        <td><t t-esc="line.product_uom.name"/></td>
                                        <td class="text-end"><t t-esc="line.quantity_done or line.product_uom_qty"/></td>
                                        <td class="text-end">
                                            <t t-esc="line.product_id.standard_price"
                                               t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="(line.quantity_done or line.product_uom_qty) * line.product_id.standard_price"
                                               t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Remarks -->
                        <div class="mt-3" t-if="o.note">
                            <strong>Remarks:</strong>
                            <p><t t-esc="o.note"/></p>
                        </div>

                        <!-- Signature Block -->
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div class="border-top pt-2 mt-5">
                                    <strong>Issued By</strong>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div class="border-top pt-2 mt-5">
                                    <strong>Received By</strong>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <div class="border-top pt-2 mt-5">
                                    <strong>Approved By</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
