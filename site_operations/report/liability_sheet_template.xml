<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_liability_sheet_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="sheet">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ── Title ── -->
                        <div class="row mb-4">
                            <div class="col-12 text-center">
                                <h2 style="font-weight:700; letter-spacing:1px;">
                                    LIABILITY SHEET
                                </h2>
                                <h4 style="color:#555;">
                                    <t t-esc="sheet.name"/>
                                </h4>
                            </div>
                        </div>

                        <!-- ── Header Info ── -->
                        <div class="row mb-3">
                            <div class="col-6">
                                <table class="table table-sm" style="font-size:13px;">
                                    <tr>
                                        <td style="width:45%;font-weight:600;">Project</td>
                                        <td><t t-esc="sheet.project_analytic_account_id.name or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight:600;">Period</td>
                                        <td>
                                            <t t-esc="sheet.date_from.strftime('%d-%b-%Y') if sheet.date_from else '-'"/>
                                            &amp;nbsp;to&amp;nbsp;
                                            <t t-esc="sheet.date_to.strftime('%d-%b-%Y') if sheet.date_to else '-'"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight:600;">Status</td>
                                        <td>
                                            <span t-attf-style="text-transform:uppercase; font-weight:600; color:#{
                                                'draft' == sheet.state and '#6c757d' or
                                                'submitted' == sheet.state and '#fd7e14' or
                                                'approved' == sheet.state and '#0d6efd' or
                                                '#198754'}">
                                                <t t-esc="dict(sheet._fields['state'].selection).get(sheet.state, sheet.state)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm" style="font-size:13px;">
                                    <tr>
                                        <td style="width:45%;font-weight:600;">Project Manager</td>
                                        <td><t t-esc="sheet.pm_id.name or '-'"/></td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight:600;">PM Signed</td>
                                        <td>
                                            <t t-if="sheet.pm_is_signed">
                                                ✓ Yes —
                                                <t t-esc="sheet.pm_signature_date.strftime('%d-%b-%Y %H:%M') if sheet.pm_signature_date else ''"/>
                                            </t>
                                            <t t-else="">Not yet signed</t>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="font-weight:600;">Print Date</td>
                                        <td>
                                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%b-%Y %H:%M')"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ── Summary Boxes ── -->
                        <div class="row mb-4 text-center">
                            <div class="col-3">
                                <div style="border:1px solid #dee2e6; border-radius:4px; padding:8px; background:#f8f9fa;">
                                    <div style="font-size:11px; color:#6c757d; text-transform:uppercase; font-weight:600;">Total Liability</div>
                                    <div style="font-size:16px; font-weight:700;">
                                        <t t-esc="'{:,.2f}'.format(sheet.total_liability)"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div style="border:1px solid #dee2e6; border-radius:4px; padding:8px; background:#fff3cd;">
                                    <div style="font-size:11px; color:#6c757d; text-transform:uppercase; font-weight:600;">Recommended</div>
                                    <div style="font-size:16px; font-weight:700;">
                                        <t t-esc="'{:,.2f}'.format(sheet.total_recommended)"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div style="border:1px solid #dee2e6; border-radius:4px; padding:8px; background:#cfe2ff;">
                                    <div style="font-size:11px; color:#6c757d; text-transform:uppercase; font-weight:600;">Approved</div>
                                    <div style="font-size:16px; font-weight:700;">
                                        <t t-esc="'{:,.2f}'.format(sheet.total_approved)"/>
                                    </div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div style="border:1px solid #dee2e6; border-radius:4px; padding:8px; background:#d1e7dd;">
                                    <div style="font-size:11px; color:#6c757d; text-transform:uppercase; font-weight:600;">Paid</div>
                                    <div style="font-size:16px; font-weight:700;">
                                        <t t-esc="'{:,.2f}'.format(sheet.total_paid)"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ── Liability Lines Table ── -->
                        <table class="table table-sm table-bordered" style="font-size:12px;">
                            <thead>
                                <tr style="background:#343a40; color:#fff;">
                                    <th class="text-center" style="width:4%;">#</th>
                                    <th style="width:20%;">Vendor / Partner</th>
                                    <th style="width:20%;">Description</th>
                                    <th class="text-right" style="width:10%;">Opening Balance</th>
                                    <th class="text-right" style="width:10%;">New Liability</th>
                                    <th class="text-right" style="width:10%;">Total Liability</th>
                                    <th class="text-right" style="width:10%;">Recommended</th>
                                    <th class="text-right" style="width:10%;">Approved</th>
                                    <th class="text-right" style="width:6%;">Paid</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sheet.line_ids" t-as="line">
                                    <tr t-attf-style="background:#{line_index % 2 == 0 and '#f8f9fa' or '#fff'}">
                                        <td class="text-center">
                                            <t t-esc="line_index + 1"/>
                                        </td>
                                        <td style="font-weight:500;">
                                            <t t-esc="line.partner_id.name or '-'"/>
                                        </td>
                                        <td>
                                            <t t-esc="line.description or '-'"/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.2f}'.format(line.opening_balance)"/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.2f}'.format(line.new_liability)"/>
                                        </td>
                                        <td class="text-right" style="font-weight:600;">
                                            <t t-esc="'{:,.2f}'.format(line.liability_amount)"/>
                                        </td>
                                        <td class="text-right">
                                            <t t-esc="'{:,.2f}'.format(line.recommended_amount)"/>
                                        </td>
                                        <td class="text-right" style="font-weight:600; color:#0d6efd;">
                                            <t t-esc="'{:,.2f}'.format(line.approved_amount)"/>
                                        </td>
                                        <td class="text-right" style="color:#198754;">
                                            <t t-esc="'{:,.2f}'.format(line.paid_amount)"/>
                                        </td>
                                    </tr>
                                </t>
                                <!-- Totals row -->
                                <tr style="background:#e9ecef; font-weight:700; border-top:2px solid #adb5bd;">
                                    <td colspan="5" class="text-right" style="font-size:12px;">TOTALS</td>
                                    <td class="text-right"><t t-esc="'{:,.2f}'.format(sheet.total_liability)"/></td>
                                    <td class="text-right"><t t-esc="'{:,.2f}'.format(sheet.total_recommended)"/></td>
                                    <td class="text-right" style="color:#0d6efd;"><t t-esc="'{:,.2f}'.format(sheet.total_approved)"/></td>
                                    <td class="text-right" style="color:#198754;"><t t-esc="'{:,.2f}'.format(sheet.total_paid)"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ── Signature Block ── -->
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                <div style="border-top:1px solid #000; padding-top:4px; margin-top:40px;">
                                    <div style="font-weight:600;">Prepared By</div>
                                    <div style="font-size:11px; color:#555;">Site Accountant</div>
                                </div>
                            </div>
                            <div class="col-4 text-center">
                                <t t-if="sheet.pm_is_signed">
                                    <div style="border-top:2px solid #198754; padding-top:4px; margin-top:40px;">
                                        <div style="font-weight:600; color:#198754;">
                                            ✓ <t t-esc="sheet.pm_id.name or 'Project Manager'"/>
                                        </div>
                                        <div style="font-size:11px; color:#555;">Project Manager</div>
                                        <div style="font-size:10px; color:#6c757d;">
                                            Signed: <t t-esc="sheet.pm_signature_date.strftime('%d-%b-%Y %H:%M') if sheet.pm_signature_date else ''"/>
                                        </div>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div style="border-top:1px solid #000; padding-top:4px; margin-top:40px;">
                                        <div style="font-weight:600;">Project Manager</div>
                                        <div style="font-size:11px; color:#aaa;">(Not Yet Signed)</div>
                                    </div>
                                </t>
                            </div>
                            <div class="col-4 text-center">
                                <div style="border-top:1px solid #000; padding-top:4px; margin-top:40px;">
                                    <div style="font-weight:600;">Approved By</div>
                                    <div style="font-size:11px; color:#555;">CEO</div>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
