<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_bank_guarantee" model="ir.sequence">
        <field name="name">Bank Guarantee</field>
        <field name="code">x.bank.guarantee</field>
        <field name="prefix">BG/%(year)s/</field>
        <field name="padding">3</field>
    </record>

    <record id="seq_bank_guarantee_sr" model="ir.sequence">
        <field name="name">Bank Guarantee Serial</field>
        <field name="code">x.bank.guarantee.sr</field>
        <field name="prefix"></field>
        <field name="padding">3</field>
    </record>

    <record id="seq_tax_notice_order" model="ir.sequence">
        <field name="name">Tax Notice &amp; Order</field>
        <field name="code">x.tax.notice.order</field>
        <field name="prefix">TN-%(year)s-</field>
        <field name="padding">4</field>
    </record>

    <record id="ir_cron_bank_guarantee_expiry" model="ir.cron">
        <field name="name">Matracon: Expire Bank Guarantees</field>
        <field name="model_id" ref="model_x_bank_guarantee"/>
        <field name="state">code</field>
        <field name="code">model._cron_expire_guarantees()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="ir_cron_tax_notice_due" model="ir.cron">
        <field name="name">Matracon: Tax Notice Due Date Alerts</field>
        <field name="model_id" ref="model_x_tax_notice_order"/>
        <field name="state">code</field>
        <field name="code">model._cron_due_date_alerts()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
