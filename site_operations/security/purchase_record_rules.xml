<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Supplement purchase_demand_raise PO rules for FO + Matracon Admin -->
        <record id="rule_po_finance_ho_all" model="ir.rule">
            <field name="name">Purchase Order: Finance HO sees all</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="groups" eval="[(4, ref('site_operations.group_finance_ho'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
        <record id="rule_po_matracon_admin_all" model="ir.rule">
            <field name="name">Purchase Order: Matracon Admin sees all</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="groups" eval="[(4, ref('site_operations.group_matracon_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
