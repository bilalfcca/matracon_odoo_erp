<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ── Site Accountant ──────────────────────────────────────────────
             Uploads vendor bills, submits liability sheets, reads issuances.
        ─────────────────────────────────────────────────────────────────── -->
        <record id="group_site_accountant" model="res.groups">
            <field name="name">Site Accountant</field>
            <field name="privilege_id" ref="purchase_demand_raise.res_groups_privilege_demand_raise"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
            <field name="comment">Site Accountants — upload vendor bills, submit liability sheets for CEO approval.</field>
        </record>

        <!-- ── Finance HO ──────────────────────────────────────────────────
             Executes payments against approved liability sheets.
        ─────────────────────────────────────────────────────────────────── -->
        <record id="group_finance_ho" model="res.groups">
            <field name="name">Finance HO</field>
            <field name="privilege_id" ref="purchase_demand_raise.res_groups_privilege_demand_raise"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_manager'))]"/>
            <field name="comment">Finance Head Office — executes vendor payments against approved liability sheets.</field>
        </record>
    </data>
</odoo>
