<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ── Liability Sheet: Site Accountant sees only their project ──── -->
        <record id="rule_liability_sheet_site_accountant" model="ir.rule">
            <field name="name">Liability Sheet: Site Accountant sees own project</field>
            <field name="model_id" ref="model_x_liability_sheet"/>
            <field name="domain_force">[('project_analytic_account_id', '=', user.x_default_analytic_account_id.id)]</field>
            <field name="groups" eval="[(4, ref('site_operations.group_site_accountant'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ── Material Issuance: Site Store sees only own project ────────── -->
        <record id="rule_material_issuance_site_store" model="ir.rule">
            <field name="name">Material Issuance: Site Store sees own project</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">['|',
                ('x_transfer_purpose', 'not in', ['material_issuance', 'site_to_site']),
                ('x_issuance_project_id', '=', user.x_default_analytic_account_id.id)
            ]</field>
            <field name="groups" eval="[(4, ref('purchase_demand_raise.group_site_store'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ── Material Issuance: Site Accountant cannot see any MI/S2S ──── -->
        <!-- Site Accountants only deal with liability sheets and vendor bills.
             They have NO access to material issuance or site-to-site records. -->
        <record id="rule_material_issuance_site_accountant" model="ir.rule">
            <field name="name">Material Issuance: Site Accountant blocked from MI/S2S</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">[('x_transfer_purpose', 'not in', ['material_issuance', 'site_to_site'])]</field>
            <field name="groups" eval="[(4, ref('site_operations.group_site_accountant'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Administrators: see all material issuances and liability sheets -->
        <record id="rule_material_issuance_admin" model="ir.rule">
            <field name="name">Material Issuance: Administrators see all</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
        <record id="rule_liability_sheet_admin" model="ir.rule">
            <field name="name">Liability Sheet: Administrators see all</field>
            <field name="model_id" ref="model_x_liability_sheet"/>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
