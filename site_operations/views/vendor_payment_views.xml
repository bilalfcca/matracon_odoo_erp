<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_form_site_ops" model="ir.ui.view">
        <field name="name">account.payment.form.site.ops</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Hide Odoo default payment state bar when using Matracon liability workflow -->
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="attributes">
                <attribute name="invisible">payment_type == 'outbound' and (x_liability_sheet_id or x_ceo_direct_payment)</attribute>
            </xpath>

            <!-- Hide standard Confirm/Cancel from CEO on direct payments -->
            <xpath expr="//button[@name='action_post']" position="attributes">
                <attribute name="invisible">x_ceo_direct_payment and x_viewer_is_ceo_only</attribute>
            </xpath>

            <!-- WHT Certificate stat button -->
            <xpath expr="//sheet" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_wht_certificates"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-certificate"
                            invisible="x_wht_certificate_count == 0">
                        <field name="x_wht_certificate_count"
                               widget="statinfo"
                               string="WHT Certs"/>
                    </button>
                </div>
            </xpath>

            <xpath expr="//header" position="inside">
                <!-- Role + direct-payment flags (invisible helpers) -->
                <field name="x_ceo_direct_payment" invisible="1"/>
                <field name="x_ceo_submitted" invisible="1"/>
                <field name="x_viewer_is_fo" invisible="1"/>
                <field name="x_viewer_is_ceo_only" invisible="1"/>

                <!-- CEO: approve salary/petty cash payments -->
                <button name="action_ceo_approve_payment"
                        type="object"
                        string="Approve (CEO)"
                        class="btn-success"
                        groups="purchase_demand_raise.group_ceo_approval"
                        invisible="x_ceo_approval_state != 'pending'"/>

                <field name="x_payment_category" invisible="1"/>
                <field name="x_ceo_approval_state"
                       invisible="x_payment_category not in ('salary', 'petty_cash')"
                       readonly="1"/>

                <!-- CEO Direct Payment: statusbar + Submit button -->
                <field name="x_payment_status"
                       widget="statusbar"
                       statusbar_visible="draft,in_process,paid"
                       invisible="payment_type != 'outbound' or (not x_liability_sheet_id and not x_ceo_direct_payment)"/>

                <!-- CEO submits their direct payment to FO -->
                <button name="action_ceo_submit_to_fo"
                        type="object"
                        string="Submit to Finance HO"
                        class="btn-primary"
                        groups="purchase_demand_raise.group_ceo_approval"
                        invisible="not x_ceo_direct_payment or x_viewer_is_fo or state != 'draft' or x_ceo_submitted"/>

                <!-- Print Cheque button -->
                <button name="action_print_cheque" type="object"
                        string="Print Cheque" class="btn-secondary" icon="fa-print"
                        invisible="not x_is_cheque_payment or state == 'draft'"/>

                <!-- FO buttons (hidden from CEO-only viewers on their own direct payments) -->
                <button name="action_set_in_process"
                        type="object"
                        string="Set In Process"
                        class="btn-primary"
                        groups="site_operations.group_finance_ho,purchase_demand_raise.group_head_office"
                        invisible="x_payment_status != 'draft' or payment_type != 'outbound'"/>

                <button name="action_mark_paid"
                        type="object"
                        string="Mark Paid (FO)"
                        class="btn-success"
                        groups="site_operations.group_finance_ho,purchase_demand_raise.group_head_office"
                        invisible="x_payment_status != 'in_process' or payment_type != 'outbound'"/>
            </xpath>

            <xpath expr="//field[@name='amount']" position="before">
                <field name="x_liability_sheet_line_id" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='amount']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_liability_sheet_line_id" invisible="1"/>

                <field name="x_gross_approved_amount"
                       readonly="1"
                       invisible="not x_liability_sheet_line_id"/>

                <field name="x_fund_project_id"
                       string="Fund Project (Client Receipt)"
                       invisible="payment_type != 'inbound'"
                       required="payment_type == 'inbound'"/>

                <field name="x_vendor_bank_account_id"
                       invisible="payment_type != 'outbound' or (x_ceo_direct_payment and x_viewer_is_ceo_only)"/>

                <field name="x_liability_sheet_id"
                       readonly="1"
                       invisible="payment_type != 'outbound' or not x_liability_sheet_id"/>

                <field name="x_destination_project_id"
                       string="Destination Project (Payment For)"
                       invisible="payment_type != 'outbound'"
                       required="payment_type == 'outbound' and x_liability_sheet_id"/>

                <field name="x_source_project_ids"
                       widget="many2many_tags"
                       invisible="payment_type != 'outbound' or (x_ceo_direct_payment and x_viewer_is_ceo_only)"
                       required="payment_type == 'outbound' and x_liability_sheet_id"/>

                <field name="x_cheque_number"
                       invisible="payment_type != 'outbound' or not x_is_cheque_payment or (x_ceo_direct_payment and x_viewer_is_ceo_only)"
                       required="payment_type == 'outbound' and x_is_cheque_payment and x_liability_sheet_id"/>
                <button name="action_assign_cheque_number" type="object"
                        string="Auto Assign Cheque No"
                        class="btn-secondary"
                        invisible="not x_is_cheque_payment or x_cheque_number or (x_ceo_direct_payment and x_viewer_is_ceo_only)"/>
            </xpath>

            <!-- Bank balance — hidden from CEO on direct payments -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="x_available_bank_balance"
                       string="Bank Balance"
                       readonly="1"
                       invisible="not journal_id or (x_ceo_direct_payment and x_viewer_is_ceo_only)"/>
            </xpath>

            <!-- Tax section — full-width with summary row (FO only) -->
            <xpath expr="//notebook" position="before">
                <div invisible="payment_type != 'outbound' or (not x_liability_sheet_id and not x_ceo_direct_payment) or (x_ceo_direct_payment and x_viewer_is_ceo_only)">
                    <separator string="Tax Compliance"/>
                    <field name="x_tax_line_ids" nolabel="1">
                        <list string="Tax Lines" editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="tax_type" string="Tax Type" optional="show"/>
                            <field name="tax_id" string="Tax Name"/>
                            <field name="effect" string="Effect"/>
                            <field name="amount" string="Deducted Amount" readonly="1"/>
                        </list>
                    </field>
                    <div class="d-flex justify-content-end gap-5 py-2 pe-2 border-top">
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase" style="font-size:0.75em;">Total Deducted</div>
                            <field name="x_total_tax_amount" nolabel="1" readonly="1" class="fw-bold"/>
                        </div>
                        <div class="text-end">
                            <div class="text-muted small fw-bold text-uppercase" style="font-size:0.75em;">Net Payable to Vendor</div>
                            <field name="x_net_payable" nolabel="1" readonly="1" class="fw-bold text-success fs-5"/>
                        </div>
                    </div>
                </div>
            </xpath>

            <!-- Generate WHT Certificate button (below tax section, above notebook) -->
            <xpath expr="//notebook" position="before">
                <div invisible="state not in ('in_process', 'paid', 'partial') or not x_wht_amount"
                     class="mb-2">
                    <button name="action_generate_wht_certificate"
                            type="object"
                            string="Generate WHT Certificate"
                            class="btn-warning"
                            groups="site_operations.group_finance_ho,purchase_demand_raise.group_matracon_admin"/>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="fund_allocation_tab"
                      string="Fund Allocation &amp; Tracking"
                      invisible="payment_type != 'outbound' or (x_ceo_direct_payment and x_viewer_is_ceo_only)">
                    <field name="x_allocation_ids" widget="one2many">
                        <list string="Fund Allocation" editable="bottom">
                            <field name="project_analytic_account_id" string="Source Project"/>
                            <field name="available_balance" string="Available Project Balance" readonly="1"/>
                            <field name="allocation_amount" string="Allocation Amount"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <record id="view_ho_payment_list" model="ir.ui.view">
        <field name="name">account.payment.ho.list</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list string="Finance HO Payments"
                  decoration-success="state == 'posted'"
                  decoration-warning="x_payment_status == 'in_process'"
                  decoration-muted="state == 'draft'">
                <field name="name" string="Reference"/>
                <field name="date" string="Payment Date"/>
                <field name="partner_id" string="Vendor"/>
                <field name="x_liability_sheet_id" string="Liability Sheet" optional="show"/>
                <field name="x_gross_approved_amount" string="CEO Approved" optional="show"/>
                <field name="x_destination_project_id" string="Destination Project" optional="show"/>
                <field name="amount" string="Net Payable"/>
                <field name="x_total_tax_amount" string="Taxes" optional="show"/>
                <field name="journal_id" string="Source Bank" optional="show"/>
                <field name="x_cheque_number" string="Cheque No." optional="show"/>
                <field name="x_payment_status" string="Status" widget="badge" optional="show"/>
                <field name="state" string="Posted" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ho_payment_search" model="ir.ui.view">
        <field name="name">account.payment.ho.search</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <search string="Search HO Payments">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="x_liability_sheet_id"/>
                <field name="x_destination_project_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                <filter name="filter_ceo_approved" string="From Liability Sheet"
                        domain="[('x_liability_sheet_id', '!=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_ho_vendor_payments" model="ir.actions.act_window">
        <field name="name">Finance Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('payment_type', '=', 'outbound'), ('partner_type', '=', 'supplier')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_ho_payment_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_account_payment_form_site_ops')}),
        ]"/>
        <field name="search_view_id" ref="view_ho_payment_search"/>
        <field name="context">{'default_payment_type': 'outbound', 'default_partner_type': 'supplier'}</field>
    </record>

</odoo>
