<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_payment_form_site_ops" model="ir.ui.view">
        <field name="name">account.payment.form.site.ops</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Hide Odoo default payment state bar when using Matracon liability workflow -->
            <xpath expr="//field[@name='state'][@widget='statusbar']" position="attributes">
                <attribute name="invisible">payment_type == 'outbound' and x_liability_sheet_id</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <field name="x_liability_sheet_id" invisible="1"/>
                <field name="x_is_cheque_payment" invisible="1"/>

                <field name="x_payment_status"
                       widget="statusbar"
                       statusbar_visible="draft,in_process,paid"
                       invisible="payment_type != 'outbound' or not x_liability_sheet_id"/>

                <button name="action_set_in_process"
                        type="object"
                        string="Set In Process"
                        class="btn-primary"
                        groups="site_operations.group_finance_ho,purchase_demand_raise.group_head_office"
                        invisible="x_payment_status != 'draft' or payment_type != 'outbound'"/>
            </xpath>

            <xpath expr="//field[@name='amount']" position="before">
                <field name="x_liability_sheet_line_id" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='amount']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_liability_sheet_line_id" invisible="1"/>

                <field name="x_gross_approved_amount"
                       readonly="1"
                       invisible="not x_liability_sheet_line_id"/>

                <field name="x_fund_project_id"
                       string="Fund Project (Client Receipt)"
                       invisible="payment_type != 'inbound'"
                       required="payment_type == 'inbound'"/>

                <field name="x_vendor_bank_account_id"
                       invisible="payment_type != 'outbound'"/>

                <field name="x_liability_sheet_id"
                       readonly="1"
                       invisible="payment_type != 'outbound' or not x_liability_sheet_id"/>

                <field name="x_destination_project_id"
                       string="Destination Project (Payment For)"
                       invisible="payment_type != 'outbound'"
                       required="payment_type == 'outbound' and x_liability_sheet_id"/>

                <field name="x_source_project_ids"
                       widget="many2many_tags"
                       invisible="payment_type != 'outbound'"
                       required="payment_type == 'outbound' and x_liability_sheet_id"/>

                <field name="x_cheque_number"
                       invisible="payment_type != 'outbound' or not x_is_cheque_payment"
                       required="payment_type == 'outbound' and x_is_cheque_payment and x_liability_sheet_id"/>
            </xpath>

            <!-- Bank balance directly under journal selection -->
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="x_available_bank_balance"
                       string="Bank Balance"
                       readonly="1"
                       invisible="not journal_id"/>
            </xpath>

            <!-- Tax section — optional fields, non-overlapping layout -->
            <xpath expr="//notebook" position="before">
                <div class="matracon-tax-compliance"
                     invisible="payment_type != 'outbound' or not x_liability_sheet_id">
                    <div class="matracon-tax-compliance__title">Tax Compliance</div>
                    <field name="x_wht_tax_id" string="Withholding Tax (WHT)"/>
                    <field name="x_wht_amount" readonly="1"/>
                    <field name="x_retention_tax_id" string="Retention Money"/>
                    <field name="x_retention_amount" readonly="1"/>
                    <field name="x_other_tax_id" string="Other Tax"/>
                    <field name="x_other_tax_amount" readonly="1"/>
                    <div class="matracon-tax-compliance__totals">
                        <field name="x_total_tax_amount" readonly="1"/>
                        <field name="x_net_payable" readonly="1"/>
                    </div>
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="fund_allocation_tab"
                      string="Fund Allocation &amp; Tracking"
                      invisible="payment_type != 'outbound'">
                    <field name="x_allocation_ids" widget="one2many">
                        <list string="Fund Allocation" editable="bottom">
                            <field name="project_analytic_account_id" string="Source Project"/>
                            <field name="available_balance" string="Available Project Balance" readonly="1"/>
                            <field name="allocation_amount" string="Allocation Amount"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <record id="view_ho_payment_list" model="ir.ui.view">
        <field name="name">account.payment.ho.list</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list string="Finance HO Payments"
                  decoration-success="state == 'posted'"
                  decoration-warning="x_payment_status == 'in_process'"
                  decoration-muted="state == 'draft'">
                <field name="name" string="Reference"/>
                <field name="date" string="Payment Date"/>
                <field name="partner_id" string="Vendor"/>
                <field name="x_liability_sheet_id" string="Liability Sheet" optional="show"/>
                <field name="x_gross_approved_amount" string="CEO Approved" optional="show"/>
                <field name="x_destination_project_id" string="Destination Project" optional="show"/>
                <field name="amount" string="Net Payable"/>
                <field name="x_total_tax_amount" string="Taxes" optional="show"/>
                <field name="journal_id" string="Source Bank" optional="show"/>
                <field name="x_cheque_number" string="Cheque No." optional="show"/>
                <field name="x_payment_status" string="Status" widget="badge" optional="show"/>
                <field name="state" string="Posted" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ho_payment_search" model="ir.ui.view">
        <field name="name">account.payment.ho.search</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <search string="Search HO Payments">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="x_liability_sheet_id"/>
                <field name="x_destination_project_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                <filter name="filter_ceo_approved" string="From Liability Sheet"
                        domain="[('x_liability_sheet_id', '!=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_ho_vendor_payments" model="ir.actions.act_window">
        <field name="name">Finance Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('payment_type', '=', 'outbound'), ('partner_type', '=', 'supplier')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_ho_payment_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_account_payment_form_site_ops')}),
        ]"/>
        <field name="search_view_id" ref="view_ho_payment_search"/>
        <field name="context">{'default_payment_type': 'outbound', 'default_partner_type': 'supplier'}</field>
    </record>

</odoo>
