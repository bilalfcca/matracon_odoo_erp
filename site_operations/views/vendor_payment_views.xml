<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Vendor Payments (Finance HO) — inherited account.payment form view,
         plus standalone list/search views and window action.
    ════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Inherited Form View ──────────────────────────────────────────── -->
    <record id="view_account_payment_form_site_ops" model="ir.ui.view">
        <field name="name">account.payment.form.site.ops</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Status bar for x_payment_status -->
            <xpath expr="//header" position="inside">
                <field name="x_payment_status"
                       widget="statusbar"
                       statusbar_visible="draft,in_process,paid"/>

                <button name="action_set_in_process"
                        type="object"
                        string="Set In Process"
                        class="btn-primary"
                        groups="site_operations.group_finance_ho,purchase_demand_raise.group_head_office"
                        invisible="x_payment_status != 'draft' or payment_type != 'outbound'"/>

                <button name="action_mark_paid"
                        type="object"
                        string="Mark as Paid"
                        class="btn-success"
                        groups="site_operations.group_finance_ho,purchase_demand_raise.group_head_office"
                        invisible="x_payment_status != 'in_process' or payment_type != 'outbound'"/>
            </xpath>

            <!-- Inject site ops fields after the partner field -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_fund_project_id"
                       string="Fund Project (Client Receipt)"
                       invisible="payment_type != 'inbound'"
                       required="payment_type == 'inbound'"/>
                <field name="x_vendor_bank_account_id"
                       invisible="payment_type != 'outbound'"/>
                <field name="x_liability_sheet_id"
                       invisible="payment_type != 'outbound'"/>
                <field name="x_total_liability"
                       readonly="1"
                       invisible="not x_liability_sheet_id"/>
                <field name="x_total_approved"
                       readonly="1"
                       invisible="not x_liability_sheet_id"/>
                <field name="x_destination_project_id"
                       string="Destination Project"
                       invisible="payment_type != 'outbound'"/>
                <field name="x_source_project_ids"
                       widget="many2many_tags"
                       invisible="payment_type != 'outbound'"/>
                <field name="x_available_bank_balance"
                       readonly="1"
                       invisible="payment_type != 'outbound'"/>
            </xpath>

            <!-- Fund Allocation tab -->
            <xpath expr="//notebook" position="inside">
                <page name="fund_allocation_tab"
                      string="Fund Allocation"
                      invisible="payment_type != 'outbound'">
                    <field name="x_allocation_ids" widget="one2many">
                        <list string="Fund Allocation" editable="bottom">
                            <field name="project_analytic_account_id" string="Source Project"/>
                            <field name="allocation_amount" string="Allocation Amount"/>
                            <field name="available_balance" string="Available Balance" readonly="1"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ── Finance HO Payments List View ─────────────────────────────────── -->
    <record id="view_ho_payment_list" model="ir.ui.view">
        <field name="name">account.payment.ho.list</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <list string="Finance HO Payments"
                  decoration-success="x_payment_status == 'paid'"
                  decoration-warning="x_payment_status == 'in_process'"
                  decoration-muted="x_payment_status == 'draft'">
                <field name="name" string="Reference"/>
                <field name="date" string="Payment Date"/>
                <field name="partner_id" string="Vendor"/>
                <field name="x_vendor_bank_account_id" string="Bank Account" optional="show"/>
                <field name="x_liability_sheet_id" string="Liability Sheet" optional="show"/>
                <field name="x_destination_project_id" string="Destination Project" optional="show"/>
                <field name="amount" string="Amount"/>
                <field name="journal_id" string="Journal" optional="show"/>
                <field name="x_available_bank_balance" string="Bank Balance" optional="show"/>
                <field name="x_payment_status" string="Payment Status"
                       widget="badge"
                       decoration-success="x_payment_status == 'paid'"
                       decoration-warning="x_payment_status == 'in_process'"
                       decoration-muted="x_payment_status == 'draft'"/>
                <field name="state" string="Accounting Status"
                       widget="badge"
                       decoration-success="state == 'posted'"
                       decoration-muted="state == 'draft'"
                       optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── Finance HO Payments Search View ──────────────────────────────── -->
    <record id="view_ho_payment_search" model="ir.ui.view">
        <field name="name">account.payment.ho.search</field>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <search string="Search HO Payments">
                <field name="name" string="Reference"/>
                <field name="partner_id" string="Vendor"/>
                <field name="x_liability_sheet_id" string="Liability Sheet"/>
                <field name="x_destination_project_id" string="Destination Project"/>

                <!-- ── Payment Status Filters ── -->
                <separator/>
                <filter name="filter_status_draft"
                        string="Draft"
                        domain="[('x_payment_status', '=', 'draft')]"/>
                <filter name="filter_status_in_process"
                        string="In Process"
                        domain="[('x_payment_status', '=', 'in_process')]"/>
                <filter name="filter_status_paid"
                        string="Paid"
                        domain="[('x_payment_status', '=', 'paid')]"/>

                <!-- ── Accounting Status Filters ── -->
                <separator/>
                <filter name="filter_posted"
                        string="Posted"
                        domain="[('state', '=', 'posted')]"/>

                <!-- ── Date Filters ── -->
                <separator/>
                <filter name="filter_date_this_month"
                        string="This Month"
                        domain="[('date', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>

                <!-- ── Group By ── -->
                <separator/>
                <filter name="group_by_status"
                        string="Group by Payment Status"
                        context="{'group_by': 'x_payment_status'}"/>
                <filter name="group_by_destination_project"
                        string="Group by Destination Project"
                        context="{'group_by': 'x_destination_project_id'}"/>
                <filter name="group_by_partner"
                        string="Group by Vendor"
                        context="{'group_by': 'partner_id'}"/>
                <filter name="group_by_date"
                        string="Group by Payment Date"
                        context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ── Window Action: Finance HO Payments ───────────────────────────── -->
    <record id="action_ho_vendor_payments" model="ir.actions.act_window">
        <field name="name">Finance Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('payment_type', '=', 'outbound'), ('partner_type', '=', 'supplier')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_ho_payment_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_account_payment_form_site_ops')}),
        ]"/>
        <field name="search_view_id" ref="view_ho_payment_search"/>
        <field name="context">{'default_payment_type': 'outbound', 'default_partner_type': 'supplier'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vendor payments found.
            </p>
            <p>
                Register a new vendor payment against an approved liability sheet.
            </p>
        </field>
    </record>

</odoo>
