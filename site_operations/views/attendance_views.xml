<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_attendance_sheet_form" model="ir.ui.view">
        <field name="name">x.attendance.sheet.form</field>
        <field name="model">x.attendance.sheet</field>
        <field name="arch" type="xml">
            <form string="Attendance Registry" class="matracon-attendance-form">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,verified,posted"/>
                    <button name="action_load_employees" type="object"
                            string="Load Employees" class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_import_attendance" type="object"
                            string="Import from File" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="site_operations.group_site_accountant"/>
                    <button name="action_verify" type="object"
                            string="Verify" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="site_operations.group_site_accountant"/>
                    <button name="action_post" type="object"
                            string="Post" class="btn-success"
                            invisible="state != 'verified'"
                            groups="site_operations.group_site_accountant"/>
                    <button name="action_print_attendance_sheet" type="object"
                            string="Print Report" class="btn-secondary"
                            icon="fa-print"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" class="oe_stat_button" icon="fa-users"
                                name="action_load_employees">
                            <field name="employee_count" widget="statinfo" string="Workforce"/>
                        </button>
                        <button type="object" class="oe_stat_button" icon="fa-money"
                                invisible="not salary_sheet_id">
                            <field name="salary_sheet_id" widget="statinfo" string="Salary Sheet"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="project_analytic_account_id" readonly="state != 'draft'"/>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="avg_present_pct" widget="progressbar" readonly="1"/>
                            <field name="total_present_days" readonly="1"/>
                            <field name="total_absent_days" readonly="1"/>
                            <field name="salary_sheet_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Upload Monthly Attendance (CSV or Excel)" invisible="state != 'draft'">
                        <field name="uploaded_file" filename="uploaded_filename"
                               help="Upload CSV or Excel. Header: Employee Name | 1 | 2 | … | 31. Codes: P A L H"/>
                        <field name="uploaded_filename" invisible="1"/>
                    </group>
                    <div class="matracon-attendance-legend" invisible="state == 'posted'">
                        <span class="matracon-attendance-legend__item">
                            <span class="matracon-attendance-legend__swatch matracon-attendance-legend__swatch--p"/>
                            P
                        </span>
                        <span class="matracon-attendance-legend__item">
                            <span class="matracon-attendance-legend__swatch matracon-attendance-legend__swatch--a"/>
                            A
                        </span>
                        <span class="matracon-attendance-legend__item">
                            <span class="matracon-attendance-legend__swatch matracon-attendance-legend__swatch--l"/>
                            L
                        </span>
                        <span class="matracon-attendance-legend__item">
                            <span class="matracon-attendance-legend__swatch matracon-attendance-legend__swatch--h"/>
                            H
                        </span>
                    </div>
                    <notebook>
                        <page string="Daily Attendance Registry">
                            <field name="line_ids" readonly="state == 'posted'">
                                <list editable="bottom" class="matracon-attendance-grid">
                                    <field name="employee_id" readonly="1"/>
                                    <field name="day_01" optional="show"/>
                                    <field name="day_02" optional="show"/>
                                    <field name="day_03" optional="show"/>
                                    <field name="day_04" optional="show"/>
                                    <field name="day_05" optional="show"/>
                                    <field name="day_06" optional="show"/>
                                    <field name="day_07" optional="show"/>
                                    <field name="day_08" optional="show"/>
                                    <field name="day_09" optional="show"/>
                                    <field name="day_10" optional="show"/>
                                    <field name="day_11" optional="show"/>
                                    <field name="day_12" optional="show"/>
                                    <field name="day_13" optional="show"/>
                                    <field name="day_14" optional="show"/>
                                    <field name="day_15" optional="show"/>
                                    <field name="day_16" optional="show"/>
                                    <field name="day_17" optional="show"/>
                                    <field name="day_18" optional="show"/>
                                    <field name="day_19" optional="show"/>
                                    <field name="day_20" optional="show"/>
                                    <field name="day_21" optional="show"/>
                                    <field name="day_22" optional="show"/>
                                    <field name="day_23" optional="show"/>
                                    <field name="day_24" optional="show"/>
                                    <field name="day_25" optional="show"/>
                                    <field name="day_26" optional="show"/>
                                    <field name="day_27" optional="show"/>
                                    <field name="day_28" optional="show"/>
                                    <field name="day_29" optional="hide"/>
                                    <field name="day_30" optional="hide"/>
                                    <field name="day_31" optional="hide"/>
                                    <field name="total_display" string="Total" readonly="1"/>
                                    <field name="x_advance_amount" string="Advance Recovery" optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_attendance_sheet_list" model="ir.ui.view">
        <field name="name">x.attendance.sheet.list</field>
        <field name="model">x.attendance.sheet</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_analytic_account_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="employee_count"/>
                <field name="avg_present_pct"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_attendance_sheet" model="ir.actions.act_window">
        <field name="name">Attendance Registry</field>
        <field name="res_model">x.attendance.sheet</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
