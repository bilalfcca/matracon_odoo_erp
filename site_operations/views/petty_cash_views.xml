<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_petty_cash_fund_form" model="ir.ui.view">
        <field name="name">x.petty.cash.fund.form</field>
        <field name="model">x.petty.cash.fund</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Fund">
                <sheet>
                    <group>
                        <field name="is_ho_fund"/>
                        <field name="project_analytic_account_id"
                               readonly="1"
                               invisible="is_ho_fund"/>
                        <field name="balance" readonly="1"/>
                        <field name="total_released" readonly="1"/>
                        <field name="total_expensed" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <notebook>
                        <page string="Requests">
                            <field name="request_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="requested_amount"/>
                                    <field name="released_amount"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Expenses">
                            <field name="expense_ids">
                                <list editable="bottom">
                                    <field name="expense_date"/>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_petty_cash_request_form" model="ir.ui.view">
        <field name="name">x.petty.cash.request.form</field>
        <field name="model">x.petty.cash.request</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Request">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,ceo_approved,released,confirmed"/>
                    <button name="action_submit" type="object" string="Submit to Finance HO"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="site_operations.group_site_accountant"/>
                    <button name="action_ceo_approve" type="object" string="Approve (CEO)"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="purchase_demand_raise.group_ceo_approval"/>
                    <button name="action_release" type="object" string="Release Petty Cash"
                            class="btn-primary" invisible="state != 'ceo_approved'"
                            groups="site_operations.group_finance_ho"/>
                    <button name="action_confirm_receipt" type="object" string="Confirm Receipt"
                            class="btn-success" invisible="state != 'released'"
                            groups="site_operations.group_site_accountant"/>
                    <button name="action_print_petty_cash_request" type="object"
                            string="Print Report" class="btn-secondary"
                            icon="fa-print"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_fund"
                                class="oe_stat_button" icon="fa-money">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="current_balance" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </span>
                                <span class="o_stat_text">Site Cash Balance</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="fund_id" readonly="state != 'draft'"/>
                        <field name="project_analytic_account_id" readonly="1"/>
                        <field name="requested_amount" readonly="state != 'draft'"/>
                        <field name="reason" readonly="state != 'draft'"/>
                        <field name="ceo_amount_type"
                               invisible="state not in ('submitted', 'ceo_approved', 'released', 'confirmed')"
                               readonly="state != 'submitted'"/>
                        <field name="ceo_approved_amount"
                               invisible="state not in ('submitted', 'ceo_approved', 'released', 'confirmed')"
                               readonly="state != 'submitted'"/>
                        <field name="released_amount" readonly="1"/>
                        <field name="payment_id" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_petty_cash_request_list" model="ir.ui.view">
        <field name="name">x.petty.cash.request.list</field>
        <field name="model">x.petty.cash.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_analytic_account_id"/>
                <field name="requested_amount"/>
                <field name="ceo_approved_amount" optional="show"/>
                <field name="released_amount"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-info="state == 'ceo_approved'"
                       decoration-primary="state == 'released'"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_petty_cash_expense_form" model="ir.ui.view">
        <field name="name">x.petty.cash.expense.form</field>
        <field name="model">x.petty.cash.expense</field>
        <field name="arch" type="xml">
            <form string="Petty Cash Expense">
                <header>
                    <button name="action_post" type="object" string="Post Expense"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="site_operations.group_site_accountant,site_operations.group_finance_ho,purchase_demand_raise.group_head_office"/>
                    <button name="action_print_expense_voucher" type="object"
                            string="Print Voucher" class="btn-secondary"
                            icon="fa-print"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Fund">
                            <field name="fund_id" readonly="state == 'posted'"/>
                            <field name="project_analytic_account_id" readonly="1"/>
                            <field name="available_balance" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   force_save="1"/>
                        </group>
                        <group string="Expense Details">
                            <field name="expense_date" readonly="state == 'posted'"/>
                            <field name="category" readonly="state == 'posted'"/>
                            <field name="journal_id" readonly="state == 'posted'"
                                   domain="[('type', 'in', ('cash', 'bank', 'general'))] + ([('x_site_ids', 'in', [project_analytic_account_id])] if project_analytic_account_id else [])"/>
                            <field name="name" string="Description" readonly="state == 'posted'"/>
                            <field name="amount" readonly="state == 'posted'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Receipt / Voucher">
                        <field name="receipt" widget="binary"
                               filename="receipt_filename"
                               string="Upload Receipt"
                               readonly="state == 'posted'"/>
                        <field name="receipt_filename" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_petty_cash_expense_list" model="ir.ui.view">
        <field name="name">x.petty.cash.expense.list</field>
        <field name="model">x.petty.cash.expense</field>
        <field name="arch" type="xml">
            <list>
                <field name="expense_date"/>
                <field name="name"/>
                <field name="project_analytic_account_id"/>
                <field name="category"/>
                <field name="amount"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_petty_cash_request" model="ir.actions.act_window">
        <field name="name">Petty Cash Requests</field>
        <field name="res_model">x.petty.cash.request</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_petty_cash_expense" model="ir.actions.act_window">
        <field name="name">Petty Cash Expenses</field>
        <field name="res_model">x.petty.cash.expense</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_petty_cash_fund" model="ir.actions.act_window">
        <field name="name">Petty Cash Funds</field>
        <field name="res_model">x.petty.cash.fund</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
