<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Project Financial Overview — CEO / CFO / Finance HO dashboard
    ════════════════════════════════════════════════════════════════════════ -->

    <record id="view_project_financial_list" model="ir.ui.view">
        <field name="name">project.project.financial.list</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Project Financial Overview"
                  decoration-danger="x_available_balance &lt; 0"
                  decoration-success="x_available_balance &gt; 0">
                <field name="name" string="Project"/>
                <field name="x_analytic_account_id" string="Analytic Account" optional="show"/>
                <field name="x_funds_received" string="Funds Received" sum="Total Received"/>
                <field name="x_total_spent" string="Total Spent" sum="Total Spent"/>
                <field name="x_available_balance" string="Available Balance" sum="Total Available"/>
                <field name="x_total_vendor_liability" string="Vendor Liabilities" sum="Vendor Liab." optional="show"/>
                <field name="x_total_sub_liability" string="Sub Liabilities" sum="Sub Liab." optional="show"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_project_financial_form" model="ir.ui.view">
        <field name="name">project.project.financial.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group[1]" position="before">
                <group string="Project Fund Summary" name="matracon_fund_summary">
                    <group>
                        <field name="x_analytic_account_id"/>
                        <field name="x_funds_received" readonly="1"/>
                        <field name="x_total_spent" readonly="1"/>
                    </group>
                    <group>
                        <field name="x_available_balance" readonly="1"/>
                        <field name="x_total_vendor_liability" readonly="1"/>
                        <field name="x_total_sub_liability" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <group string="Site Team" name="matracon_site_team">
                    <field name="x_site_store_user_ids" widget="many2many_tags"/>
                    <field name="x_site_accountant_user_ids" widget="many2many_tags"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_project_financial_search" model="ir.ui.view">
        <field name="name">project.project.financial.search</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <search string="Projects">
                <field name="name"/>
                <field name="x_analytic_account_id"/>
                <filter name="filter_negative_balance"
                        string="Negative Balance"
                        domain="[('x_available_balance', '&lt;', 0)]"/>
                <filter name="filter_positive_balance"
                        string="Positive Balance"
                        domain="[('x_available_balance', '&gt;', 0)]"/>
            </search>
        </field>
    </record>

    <record id="action_project_financial_overview" model="ir.actions.act_window">
        <field name="name">Project Financial Overview</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_project_financial_list"/>
        <field name="search_view_id" ref="view_project_financial_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No projects configured yet.
            </p>
            <p>
                Each site project shows funds received, amounts spent, available balance,
                and outstanding liabilities — all driven from tagged payments and payables.
            </p>
        </field>
    </record>

</odoo>
