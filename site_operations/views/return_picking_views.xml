<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Return Wizard — add Issued / Returned / Outstanding columns
         so site store can see exactly how much they can return.
    ════════════════════════════════════════════════════════════════════════ -->
    <record id="view_stock_return_picking_form_site_ops" model="ir.ui.view">
        <field name="name">stock.return.picking.form.site.ops</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
        <field name="arch" type="xml">

            <!-- Add columns after the quantity field -->
            <xpath expr="//field[@name='quantity']" position="after">
                <field name="x_issued_qty"
                       string="Issued"
                       readonly="1"
                       optional="show"/>
                <field name="x_returned_qty"
                       string="Already Returned"
                       readonly="1"
                       optional="show"/>
                <field name="x_outstanding_qty"
                       string="Outstanding"
                       readonly="1"
                       optional="show"
                       decoration-danger="quantity > x_outstanding_qty and x_outstanding_qty > 0"
                       decoration-success="quantity &lt;= x_outstanding_qty and x_outstanding_qty > 0"/>
            </xpath>

        </field>
    </record>
</odoo>
