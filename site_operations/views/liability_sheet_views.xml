<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Liability Sheet — Form, List, Search Views + Window Action
    ════════════════════════════════════════════════════════════════════════ -->

    <record id="view_liability_sheet_form" model="ir.ui.view">
        <field name="name">x.liability.sheet.form</field>
        <field name="model">x.liability.sheet</field>
        <field name="arch" type="xml">
            <form string="Liability Sheet" class="matracon-liability-stats">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,paid"/>

                    <!-- Site Accountant: recommend + PM upload + submit -->
                    <button name="action_download_pdf"
                            type="object"
                            string="Download for PM Signature"
                            class="btn-secondary"
                            groups="site_operations.group_site_accountant"
                            invisible="state != 'draft'"/>

                    <button name="action_submit"
                            type="object"
                            string="Submit for CEO Approval"
                            class="btn-primary"
                            groups="site_operations.group_site_accountant"
                            invisible="state != 'draft'"/>

                    <!-- CEO approval -->
                    <button name="action_ceo_approve"
                            type="object"
                            string="Approve (CEO)"
                            class="btn-success"
                            groups="purchase_demand_raise.group_ceo_approval"
                            invisible="state != 'submitted'"/>

                    <button name="action_reset_draft"
                            type="object"
                            string="Reset to Draft"
                            class="btn-warning"
                            groups="site_operations.group_site_accountant,purchase_demand_raise.group_head_office"
                            invisible="state not in ['submitted', 'approved']"/>

                    <button name="action_refresh_from_ledger"
                            type="object"
                            string="↻ Refresh from Ledger"
                            class="btn-secondary"
                            groups="site_operations.group_site_accountant,purchase_demand_raise.group_head_office"
                            invisible="state == 'paid'"
                            title="Pull opening balance and new liability from partner ledger"/>

                    <button name="action_download_pdf"
                            type="object"
                            string="⬇ Download PDF"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>

                    <button name="action_fo_mark_paid"
                            type="object"
                            string="Mark Paid (FO)"
                            class="btn-success"
                            groups="site_operations.group_finance_ho"
                            invisible="state != 'approved'"
                            confirm="Confirm all vendor payments are posted and close this liability sheet?"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_payments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money"
                                invisible="not payment_ids">
                            <field name="payment_ids" widget="statinfo" string="Payments"/>
                        </button>
                        <button type="button" class="oe_stat_button" icon="fa-balance-scale">
                            <div class="o_stat_info">
                                <field name="total_liability" widget="statinfo" string="Total Liability"/>
                            </div>
                        </button>
                        <button type="button" class="oe_stat_button" icon="fa-thumbs-up">
                            <div class="o_stat_info">
                                <field name="total_recommended" widget="statinfo" string="Recommended"/>
                            </div>
                        </button>
                        <button type="button" class="oe_stat_button" icon="fa-check-circle">
                            <div class="o_stat_info">
                                <field name="total_approved" widget="statinfo" string="Approved"/>
                            </div>
                        </button>
                        <button type="button" class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <field name="total_paid" widget="statinfo" string="Paid"/>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" placeholder="LS/PROJECT/Mon-YYYY-Mon-YYYY"/>
                        </h1>
                    </div>

                    <group name="header_fields">
                        <group name="left">
                            <field name="project_analytic_account_id"
                                   readonly="state not in ['draft']"/>
                            <field name="date_from"
                                   readonly="state not in ['draft']"/>
                            <field name="date_to"
                                   readonly="state not in ['draft']"/>
                        </group>
                    </group>

                    <!-- PM physical signature upload (no PM user field — PM has no license) -->
                    <group string="PM Signed Document (Required before Submit)"
                           invisible="state == 'paid'">
                        <field name="pm_signed_sheet"
                               widget="binary"
                               filename="pm_signed_sheet_filename"
                               string="Upload PM Signed Copy"
                               readonly="state not in ['draft']"/>
                        <field name="pm_signed_sheet_filename" invisible="1"/>
                    </group>

                    <notebook>
                        <page name="lines_tab" string="Liability Lines">
                            <field name="line_ids" widget="one2many"
                                   readonly="state == 'paid'">
                                <list string="Liability Lines" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="x_is_ceo" column_invisible="1"/>
                                    <field name="description"/>
                                    <field name="partner_id" readonly="is_locked"/>
                                    <field name="opening_balance" readonly="is_locked"/>
                                    <field name="new_liability" readonly="is_locked"/>
                                    <field name="liability_amount" readonly="1"/>
                                    <field name="recommended_amount"
                                           readonly="parent.state != 'draft'"/>
                                    <field name="decision"
                                           readonly="parent.state != 'submitted' or is_locked or not x_is_ceo"/>
                                    <field name="approved_amount"
                                           readonly="parent.state != 'submitted' or is_locked or not x_is_ceo"/>
                                    <field name="approved_pct" optional="show" readonly="1"/>
                                    <field name="remarks" optional="show"/>
                                    <field name="paid_amount" readonly="1" optional="show"/>
                                    <field name="balance" readonly="1" optional="show"/>
                                    <field name="payment_id" optional="hide" readonly="1"/>
                                    <field name="is_locked" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_liability_sheet_list" model="ir.ui.view">
        <field name="name">x.liability.sheet.list</field>
        <field name="model">x.liability.sheet</field>
        <field name="arch" type="xml">
            <list string="Liability Sheets"
                  decoration-success="state == 'paid'"
                  decoration-primary="state == 'approved'"
                  decoration-warning="state == 'submitted'"
                  decoration-muted="state == 'draft'">
                <field name="name" string="Reference"/>
                <field name="project_analytic_account_id" string="Project"/>
                <field name="date_from" string="Date From"/>
                <field name="date_to" string="Date To"/>
                <field name="total_liability" string="Total Liability"/>
                <field name="total_recommended" string="Recommended" optional="show"/>
                <field name="total_approved" string="Approved"/>
                <field name="total_paid" string="Paid" optional="show"/>
                <field name="state" string="Status"
                       widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-primary="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="view_liability_sheet_search" model="ir.ui.view">
        <field name="name">x.liability.sheet.search</field>
        <field name="model">x.liability.sheet</field>
        <field name="arch" type="xml">
            <search string="Search Liability Sheets">
                <field name="name" string="Reference"/>
                <field name="project_analytic_account_id" string="Project"/>
                <separator/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="filter_paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <separator/>
                <filter name="filter_this_month"
                        string="This Month"
                        domain="[('date_from', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="group_by_project" string="Group by Project"
                        context="{'group_by': 'project_analytic_account_id'}"/>
                <filter name="group_by_state" string="Group by Status"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_liability_sheet" model="ir.actions.act_window">
        <field name="name">Liability Sheets</field>
        <field name="res_model">x.liability.sheet</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_liability_sheet_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_liability_sheet_form')}),
        ]"/>
        <field name="search_view_id" ref="view_liability_sheet_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No liability sheets found.</p>
            <p>Create a liability sheet to track vendor and subcontractor payments for a project.</p>
        </field>
    </record>

</odoo>
