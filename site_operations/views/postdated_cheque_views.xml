<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_postdated_cheque_list" model="ir.ui.view">
        <field name="name">x.postdated.cheque.list</field>
        <field name="model">x.postdated.cheque</field>
        <field name="arch" type="xml">
            <list string="Post-Dated Cheques"
                  decoration-danger="is_overdue"
                  decoration-success="state == 'cleared'"
                  decoration-muted="state == 'cancelled'"
                  decoration-warning="state == 'bounced'">
                <field name="name" string="Cheque No"/>
                <field name="bank_journal_id" string="Bank"/>
                <field name="partner_id" string="Payee"/>
                <field name="amount"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="issue_date" string="Issued"/>
                <field name="cheque_date" string="Cheque Date"/>
                <field name="days_to_clearance" string="Days to Clear"/>
                <field name="is_overdue" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'cleared'"
                       decoration-danger="state == 'bounced'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_postdated_cheque_form" model="ir.ui.view">
        <field name="name">x.postdated.cheque.form</field>
        <field name="model">x.postdated.cheque</field>
        <field name="arch" type="xml">
            <form string="Post-Dated Cheque">
                <header>
                    <button name="action_mark_cleared" type="object"
                            string="Mark Cleared"
                            class="btn-success"
                            invisible="state != 'pending'"/>
                    <button name="action_mark_bounced" type="object"
                            string="Mark Bounced"
                            class="btn-danger"
                            invisible="state != 'pending'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible="state in ('cleared', 'bounced', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,cleared,bounced,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Cheque Details">
                            <field name="name" string="Cheque No"
                                   readonly="state != 'pending'"/>
                            <field name="bank_journal_id"
                                   readonly="state != 'pending'"/>
                            <field name="partner_id" string="Payee"
                                   readonly="state != 'pending'"/>
                            <field name="amount" readonly="state != 'pending'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Dates &amp; Status">
                            <field name="issue_date" readonly="state != 'pending'"/>
                            <field name="cheque_date" readonly="state != 'pending'"/>
                            <field name="days_to_clearance" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                            <field name="payment_id" readonly="state != 'pending'"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_postdated_cheque_search" model="ir.ui.view">
        <field name="name">x.postdated.cheque.search</field>
        <field name="model">x.postdated.cheque</field>
        <field name="arch" type="xml">
            <search string="Search Post-Dated Cheques">
                <field name="name" string="Cheque No"/>
                <field name="partner_id" string="Payee"/>
                <field name="bank_journal_id" string="Bank"/>
                <separator/>
                <filter name="filter_pending" string="Pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter name="filter_overdue" string="Overdue"
                        domain="[('state', '=', 'pending'), ('cheque_date', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_cleared" string="Cleared"
                        domain="[('state', '=', 'cleared')]"/>
                <filter name="filter_bounced" string="Bounced"
                        domain="[('state', '=', 'bounced')]"/>
                <separator/>
                <filter name="group_bank" string="Group by Bank"
                        context="{'group_by': 'bank_journal_id'}"/>
                <filter name="group_state" string="Group by State"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_postdated_cheque" model="ir.actions.act_window">
        <field name="name">Post-Dated Cheques</field>
        <field name="res_model">x.postdated.cheque</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_postdated_cheque_search"/>
    </record>

</odoo>
