<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_site_store_dashboard_form" model="ir.ui.view">
        <field name="name">x.site.store.dashboard.form</field>
        <field name="model">x.site.store.dashboard</field>
        <field name="arch" type="xml">
            <form string="Site Store Dashboard" class="o_matracon_dashboard" create="false" delete="false">
                <header>
                    <button name="action_refresh" type="object" string="Refresh"
                            class="btn-secondary" icon="fa-refresh"/>
                    <button name="action_raise_pr" type="object" string="New PR"
                            class="btn-primary"/>
                    <button name="action_open_issuance" type="object"
                            string="Issuance" class="btn-secondary"/>
                    <button name="action_open_transfers" type="object"
                            string="Transfer" class="btn-secondary"/>
                    <button name="action_clear_filters" type="object"
                            string="Clear Filters" class="btn-secondary" icon="fa-times"/>
                </header>
                <sheet>

                    <div class="oe_title mb-3">
                        <h1><field name="project_name" readonly="1" class="oe_inline"/></h1>
                        <p class="text-muted mb-0">
                            <field name="user_name" readonly="1" class="oe_inline"/>
                            — Site Store Manager
                        </p>
                    </div>

                    <div class="matracon-dash-filters">
                        <span class="matracon-dash-filters__label">Filters</span>
                        <div class="matracon-dash-filters__field">
                            <field name="filter_pr_state" nolabel="1" placeholder="PR Status"/>
                        </div>
                        <div class="matracon-dash-filters__field">
                            <field name="filter_period_days" nolabel="1" placeholder="Date Range"/>
                        </div>
                        <div class="matracon-dash-filters__field">
                            <field name="filter_section" nolabel="1" placeholder="Section"/>
                        </div>
                    </div>

                    <div class="alert alert-warning matracon-dash-alert d-flex align-items-start gap-3 mb-4"
                         role="alert" invisible="not has_stock_alert">
                        <i class="fa fa-exclamation-triangle fa-lg mt-1" title="Alert"/>
                        <div class="flex-grow-1">
                            <strong>Replenishment Alert: Critical Stock Level</strong>
                            <div class="mt-1">
                                <field name="alert_message" readonly="1" nolabel="1" class="oe_inline"/>
                            </div>
                        </div>
                        <button name="action_raise_pr" type="object"
                                string="Raise PR" class="btn btn-warning btn-sm flex-shrink-0"/>
                    </div>

                    <div class="row g-3 mb-4">

                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-3 px-md-4">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <small class="text-muted text-uppercase fw-bold"
                                               style="font-size:0.7rem; letter-spacing:0.06em;">Open Requisitions</small>
                                        <i class="fa fa-file-text-o text-muted" title="PRs"/>
                                    </div>
                                    <div class="fw-bold text-primary mt-2 mb-1"
                                         style="font-size:2.4rem; line-height:1.1;">
                                        <field name="open_pr_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                                        <small class="text-warning fw-bold">
                                            <i class="fa fa-pencil me-1" title="Signature"/>
                                            <field name="pending_signature_count" nolabel="1" readonly="1" class="oe_inline"/>
                                            Pending Signature
                                        </small>
                                        <button name="action_open_prs" type="object"
                                                string="View" class="btn btn-sm btn-outline-primary"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-3 px-md-4">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <small class="text-muted text-uppercase fw-bold"
                                               style="font-size:0.7rem; letter-spacing:0.06em;">Arrivals Today</small>
                                        <i class="fa fa-truck text-muted" title="Arrivals"/>
                                    </div>
                                    <div class="fw-bold text-success mt-2 mb-1"
                                         style="font-size:2.4rem; line-height:1.1;">
                                        <field name="arrivals_today_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                                        <small class="text-info fw-bold">
                                            <i class="fa fa-exclamation-circle me-1" title="Partial"/>
                                            <field name="partial_receipts_count" nolabel="1" readonly="1" class="oe_inline"/>
                                            Partial
                                        </small>
                                        <button name="action_open_receipts" type="object"
                                                string="View" class="btn btn-sm btn-outline-success"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-3 px-md-4">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <small class="text-muted text-uppercase fw-bold"
                                               style="font-size:0.7rem; letter-spacing:0.06em;">Issuance (MTD)</small>
                                        <i class="fa fa-sign-out text-muted" title="Issuances"/>
                                    </div>
                                    <div class="fw-bold mt-2 mb-1"
                                         style="font-size:2.4rem; line-height:1.1; color:#6f42c1;">
                                        <field name="issuance_mtd_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                                        <small class="text-muted">
                                            <field name="normal_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>% N /
                                            <field name="subcontractor_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>% S
                                        </small>
                                        <button name="action_open_issuance" type="object"
                                                string="View" class="btn btn-sm btn-outline-secondary"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-3 mb-3" invisible="filter_section not in ('all', 'prs', 'receipts')">

                        <div class="col-12 col-lg-7" invisible="filter_section not in ('all', 'prs')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header d-flex flex-wrap justify-content-between align-items-center py-2 px-3 px-md-4 gap-2"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">Active Requisitions</strong>
                                    <button name="action_open_prs" type="object"
                                            string="View All" class="btn btn-sm btn-outline-primary"/>
                                </div>
                                <div class="card-body p-0 matracon-dash-table-wrap matracon-dash-table-wrap--compact">
                                    <field name="pr_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false"
                                              decoration-warning="x_pr_state == 'draft'"
                                              decoration-success="x_pr_state in ('submitted', 'po_locked', 'dispatched')">
                                            <field name="name" string="Reference"/>
                                            <field name="date_order" string="Date"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                            <field name="x_project_analytic_account_id" string="Project" optional="hide"/>
                                            <field name="x_initiator_id" string="Requester" optional="hide"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-5" invisible="filter_section not in ('all', 'receipts')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-3 px-md-4"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">Material Receipt Status</strong>
                                </div>
                                <div class="card-body p-0">
                                    <div class="px-3 pt-2">
                                        <small class="text-muted text-uppercase fw-bold"
                                               style="font-size:0.68rem; letter-spacing:0.06em;">
                                            On Order
                                        </small>
                                    </div>
                                    <div class="matracon-dash-table-wrap matracon-dash-table-wrap--compact">
                                        <field name="on_order_po_ids" nolabel="1" readonly="1">
                                            <list create="false" delete="false" edit="false">
                                                <field name="name"/>
                                                <field name="partner_id" string="Vendor"/>
                                                <field name="x_pr_state" string="Status" widget="badge"/>
                                                <field name="date_order" string="Expected" optional="hide"/>
                                            </list>
                                        </field>
                                    </div>
                                    <div class="px-3 pt-2">
                                        <small class="text-muted text-uppercase fw-bold"
                                               style="font-size:0.68rem; letter-spacing:0.06em;">
                                            Recent GRNs
                                        </small>
                                    </div>
                                    <div class="matracon-dash-table-wrap matracon-dash-table-wrap--compact">
                                        <field name="recent_grn_ids" nolabel="1" readonly="1">
                                            <list create="false" delete="false" edit="false">
                                                <field name="name"/>
                                                <field name="partner_id" string="Vendor"/>
                                                <field name="state" widget="badge"/>
                                                <field name="date_done" string="Received" optional="hide"/>
                                            </list>
                                        </field>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="row g-3 mb-3" invisible="filter_section not in ('all', 'transfers', 'issuances')">

                        <div class="col-12 col-lg-6" invisible="filter_section not in ('all', 'transfers')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header d-flex flex-wrap justify-content-between align-items-center py-2 px-3 px-md-4 gap-2"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        <i class="fa fa-exchange me-2 text-info" title="Transfers"/>
                                        Site Transfers
                                    </strong>
                                    <button name="action_open_transfers" type="object"
                                            string="View All" class="btn btn-sm btn-outline-info"/>
                                </div>
                                <div class="card-body p-0 matracon-dash-table-wrap matracon-dash-table-wrap--compact">
                                    <field name="transfer_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false">
                                            <field name="name"/>
                                            <field name="x_issuance_project_id" string="From"/>
                                            <field name="x_dest_project_id" string="To"/>
                                            <field name="x_site_transfer_state" string="Status" widget="badge"/>
                                            <field name="state" widget="badge" optional="hide"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-lg-6" invisible="filter_section not in ('all', 'issuances')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-3 px-md-4"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">Issuance Overview</strong>
                                </div>
                                <div class="card-body px-3 px-md-4 py-3">
                                    <div class="d-flex rounded overflow-hidden mb-3 matracon-issuance-bar" style="height:28px;">
                                        <div class="d-flex align-items-center justify-content-center text-white fw-bold"
                                             style="font-size:0.78rem; background:#4e73df; flex:0 0 60%;">
                                            Normal (<field name="normal_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>%)
                                        </div>
                                        <div class="d-flex align-items-center justify-content-center text-white fw-bold"
                                             style="font-size:0.78rem; background:#e74a3b; flex:0 0 40%;">
                                            3rd Party (<field name="subcontractor_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>%)
                                        </div>
                                    </div>
                                    <div class="matracon-dash-table-wrap matracon-dash-table-wrap--compact">
                                        <field name="recent_issuance_ids" nolabel="1" readonly="1">
                                            <list create="false" delete="false" edit="false">
                                                <field name="name"/>
                                                <field name="x_contact_id" string="Contact"/>
                                                <field name="x_issue_type" string="Type" widget="badge"/>
                                                <field name="state" widget="badge"/>
                                                <field name="x_backcharge_applicable" string="Backcharge"
                                                       widget="boolean_toggle" optional="hide"/>
                                            </list>
                                        </field>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <field name="name" invisible="1"/>
                    <field name="project_analytic_account_id" invisible="1"/>
                    <field name="has_stock_alert" invisible="1"/>
                    <field name="alert_product_id" invisible="1"/>
                    <field name="alert_qty_on_hand" invisible="1"/>
                    <field name="alert_min_qty" invisible="1"/>
                    <field name="dest_receipt_count" invisible="1"/>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_store_dashboard" model="ir.actions.server">
        <field name="name">Site Store Dashboard</field>
        <field name="model_id" ref="model_x_site_store_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
