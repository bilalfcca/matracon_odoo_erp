<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_site_store_dashboard_form" model="ir.ui.view">
        <field name="name">x.site.store.dashboard.form</field>
        <field name="model">x.site.store.dashboard</field>
        <field name="arch" type="xml">
            <form string="Site Store Dashboard" create="false" delete="false">
                <header>
                    <button name="action_refresh" type="object" string="Refresh"
                            class="btn-secondary" icon="fa-refresh"/>
                    <button name="action_raise_pr" type="object" string="New PR"
                            class="btn-primary"/>
                    <button name="action_open_issuance" type="object"
                            string="Material Issuance" class="btn-secondary"/>
                    <button name="action_open_transfers" type="object"
                            string="Site Transfer" class="btn-secondary"/>
                </header>
                <sheet>

                    <!-- ── Dashboard Title ──────────────────────────────────── -->
                    <div class="oe_title">
                        <h1>
                            <field name="project_name" readonly="1" class="oe_inline"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="user_name" readonly="1" class="oe_inline"/>
                            — Site Store Manager
                        </h3>
                    </div>

                    <!-- ── Filters Card ──────────────────────────────────────── -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h6 class="card-title text-muted text-uppercase mb-3"
                                style="font-size: 0.75rem; letter-spacing: 0.08em;">
                                <i class="fa fa-filter me-1" title="Filters"/> Dashboard Filters
                            </h6>
                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">PR Status</label>
                                    <field name="filter_pr_state" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Date Range</label>
                                    <field name="filter_period_days" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Focus</label>
                                    <field name="filter_section" nolabel="1"/>
                                </div>
                            </div>
                            <div class="mt-3">
                                <button name="action_apply_filters" type="object"
                                        string="Apply Filters" class="btn btn-primary btn-sm"/>
                            </div>
                        </div>
                    </div>

                    <!-- ── Stock Alert Banner ────────────────────────────────── -->
                    <div class="alert alert-warning d-flex align-items-center gap-3 mb-4"
                         role="alert" invisible="not has_stock_alert">
                        <i class="fa fa-exclamation-triangle fa-lg" title="Alert"/>
                        <div class="flex-grow-1">
                            <strong>Replenishment Alert — Critical Stock</strong>
                            <div class="mt-1">
                                <field name="alert_message" readonly="1" nolabel="1" class="oe_inline"/>
                            </div>
                        </div>
                        <button name="action_raise_pr" type="object"
                                string="Raise PR Now" class="btn btn-warning btn-sm"/>
                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         KPI CARDS — ROW 1 (Primary metrics)
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-3">

                        <!-- Open PRs -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-primary mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="open_pr_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Open PRs</div>
                                    <div class="mt-2">
                                        <button name="action_open_prs" type="object"
                                                string="View" class="btn btn-sm btn-outline-primary"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Arrivals Today -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-success mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="arrivals_today_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Arrivals Today</div>
                                    <div class="mt-2">
                                        <button name="action_open_receipts" type="object"
                                                string="View" class="btn btn-sm btn-outline-success"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Issuances MTD -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold mb-1" style="font-size: 2.5rem; line-height: 1.1; color: #6f42c1;">
                                        <field name="issuance_mtd_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Issuances (MTD)</div>
                                    <div class="mt-2">
                                        <button name="action_open_issuance" type="object"
                                                string="View" class="btn btn-sm btn-outline-secondary"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pending Returns -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-danger mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="pending_returns_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Pending Returns</div>
                                    <div class="mt-2">
                                        <button name="action_open_returns" type="object"
                                                string="View" class="btn btn-sm btn-outline-danger"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         KPI CARDS — ROW 2 (Secondary metrics)
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-4">

                        <!-- Pending PM Signature -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-warning mb-1" style="font-size: 2.2rem; line-height: 1.1;">
                                        <field name="pending_signature_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Pending PM Signature</div>
                                </div>
                            </div>
                        </div>

                        <!-- Partial Receipts -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold mb-1" style="font-size: 2.2rem; line-height: 1.1; color: #fd7e14;">
                                        <field name="partial_receipts_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Partial Receipts</div>
                                </div>
                            </div>
                        </div>

                        <!-- Transfers Active -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-info mb-1" style="font-size: 2.2rem; line-height: 1.1;">
                                        <field name="pending_transfer_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Transfers Active</div>
                                    <div class="mt-2">
                                        <button name="action_open_transfers" type="object"
                                                string="View" class="btn btn-sm btn-outline-info"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Issuance Type Split -->
                        <div class="col-12 col-sm-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-body py-3 px-4">
                                    <div class="text-muted text-uppercase mb-3"
                                         style="font-size: 0.75rem; letter-spacing: 0.06em;">
                                        Issuance Split (MTD)
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted" style="font-size: 0.82rem;">Normal</span>
                                        <span class="fw-bold text-primary" style="font-size: 1.4rem;">
                                            <field name="normal_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>%
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted" style="font-size: 0.82rem;">Subcontractor</span>
                                        <span class="fw-bold text-danger" style="font-size: 1.4rem;">
                                            <field name="subcontractor_issuance_pct" nolabel="1" readonly="1" class="oe_inline"/>%
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         DETAIL TABLES
                    ══════════════════════════════════════════════════════ -->

                    <group string="Active Requisitions"
                           invisible="filter_section not in ('all', 'prs')">
                        <field name="pr_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-warning="x_pr_state == 'draft'"
                                  decoration-success="x_pr_state in ('submitted', 'po_locked', 'dispatched')">
                                <field name="name" string="Reference"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="date_order" string="Date"/>
                                <field name="x_initiator_id" string="Requester"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Material Receipts"
                           invisible="filter_section not in ('all', 'receipts')">
                        <label for="pending_receipt_ids" string="Receipts To Validate"/>
                        <field name="pending_receipt_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="origin" string="PO"/>
                                <field name="scheduled_date"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                        <label for="on_order_po_ids" string="On Order (Dispatched POs)"/>
                        <field name="on_order_po_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="date_order" string="Expected"/>
                                <field name="x_pr_state" string="PR Status" widget="badge"/>
                            </list>
                        </field>
                        <label for="recent_grn_ids" string="Recent GRNs (Validated)"/>
                        <field name="recent_grn_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="date_done" string="Received On"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Recent Issuances"
                           invisible="filter_section not in ('all', 'issuances')">
                        <field name="recent_issuance_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="x_contact_id" string="Contact"/>
                                <field name="x_issue_type"/>
                                <field name="x_backcharge_applicable" string="Backcharge"/>
                                <field name="x_gate_pass_outward_no" string="Gate Pass"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Site Transfers"
                           invisible="filter_section not in ('all', 'transfers')">
                        <field name="transfer_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="x_issuance_project_id" string="From Project"/>
                                <field name="x_dest_project_id" string="To Project"/>
                                <field name="x_site_transfer_state" string="Status" widget="badge"/>
                                <field name="x_is_dest_receipt" string="Dest. Receipt"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Pending Returns"
                           invisible="filter_section not in ('all', 'returns')">
                        <field name="pending_return_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name"/>
                                <field name="x_original_issuance_id" string="Original"/>
                                <field name="x_contact_id" string="Contact"/>
                                <field name="x_return_type"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <!-- Hidden fields needed for invisible conditions -->
                    <field name="name" invisible="1"/>
                    <field name="project_analytic_account_id" invisible="1"/>
                    <field name="has_stock_alert" invisible="1"/>
                    <field name="alert_product_id" invisible="1"/>
                    <field name="alert_qty_on_hand" invisible="1"/>
                    <field name="alert_min_qty" invisible="1"/>
                    <field name="dest_receipt_count" invisible="1"/>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_site_store_dashboard" model="ir.actions.server">
        <field name="name">Site Store Dashboard</field>
        <field name="model_id" ref="model_x_site_store_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
