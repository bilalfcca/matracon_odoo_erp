<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cheque_series_list" model="ir.ui.view">
        <field name="name">x.cheque.series.list</field>
        <field name="model">x.cheque.series</field>
        <field name="arch" type="xml">
            <list string="Cheque Series"
                  decoration-muted="state == 'closed'"
                  decoration-warning="state == 'exhausted'"
                  decoration-success="state == 'active'">
                <field name="name" string="Series Name"/>
                <field name="bank_journal_id" string="Bank Account"/>
                <field name="prefix"/>
                <field name="start_number"/>
                <field name="end_number"/>
                <field name="current_number" string="Next Number"/>
                <field name="issued_count" string="Issued"/>
                <field name="remaining_count" string="Remaining"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'exhausted'"
                       decoration-muted="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="view_cheque_series_form" model="ir.ui.view">
        <field name="name">x.cheque.series.form</field>
        <field name="model">x.cheque.series</field>
        <field name="arch" type="xml">
            <form string="Cheque Series">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="active,exhausted,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Series Configuration">
                            <field name="bank_journal_id"/>
                            <field name="prefix" placeholder="e.g. HBL- or MCB-A-"/>
                            <field name="pad_digits" string="Number Width (digits)"
                                   help="Set to 0 for no zero-padding"/>
                            <field name="start_number"/>
                            <field name="end_number"/>
                            <field name="current_number" string="Next Number"/>
                        </group>
                        <group string="Statistics">
                            <field name="issued_count" readonly="1"/>
                            <field name="remaining_count" readonly="1"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cheque_series_search" model="ir.ui.view">
        <field name="name">x.cheque.series.search</field>
        <field name="model">x.cheque.series</field>
        <field name="arch" type="xml">
            <search string="Search Cheque Series">
                <field name="name"/>
                <field name="bank_journal_id"/>
                <filter name="filter_active" string="Active"
                        domain="[('state', '=', 'active')]"/>
                <filter name="filter_exhausted" string="Exhausted"
                        domain="[('state', '=', 'exhausted')]"/>
            </search>
        </field>
    </record>

    <record id="action_cheque_series" model="ir.actions.act_window">
        <field name="name">Cheque Series</field>
        <field name="res_model">x.cheque.series</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cheque_series_search"/>
    </record>

</odoo>
