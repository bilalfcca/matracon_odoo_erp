<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Site Operations — Menu Placement
    ════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Single "Dashboard" in Purchase — routes to the right dashboard ──────
         The server action (action_site_store_dashboard) already handles routing:
           • Admin / PO / HO / CEO → Procurement HO Dashboard
           • Site Store              → Site Store Dashboard
         Using ONE menu item means admin sees "Dashboard" only once,
         not "Procurement HO Dashboard" + "Site Store Dashboard".
    ──────────────────────────────────────────────────────────────────────── -->
    <menuitem id="menu_procurement_ho_dashboard"
              name="Dashboard"
              parent="purchase.menu_purchase_root"
              action="site_operations.action_site_store_dashboard"
              sequence="1"
              groups="purchase_demand_raise.group_site_store,purchase_demand_raise.group_procurement_ho,purchase_demand_raise.group_ceo_approval,purchase_demand_raise.group_head_office,purchase_demand_raise.group_matracon_admin"/>

    <!-- ── Single "Dashboard" in Inventory (same routing logic) ──────────── -->
    <menuitem id="menu_site_store_dashboard"
              name="Dashboard"
              parent="stock.menu_stock_root"
              action="site_operations.action_site_store_dashboard"
              sequence="1"
              groups="purchase_demand_raise.group_site_store,purchase_demand_raise.group_procurement_ho,purchase_demand_raise.group_ceo_approval,purchase_demand_raise.group_head_office,purchase_demand_raise.group_matracon_admin"/>

    <!-- Purchase → Configuration → Site Project Configurations (Matracon Admin) -->
    <menuitem id="menu_project_site_config_matracon_admin"
              name="Site Project Configurations"
              parent="purchase.menu_purchase_config"
              action="purchase_demand_raise.action_project_site_config"
              sequence="49"
              groups="purchase_demand_raise.group_matracon_admin"/>

    <!-- Inventory → Operations → Transfers -->
    <menuitem id="menu_material_issuance"
              name="Material Issuance"
              parent="stock.menu_stock_transfers"
              action="site_operations.action_material_issuance_only"
              sequence="25"
              groups="purchase_demand_raise.group_site_store,purchase_demand_raise.group_procurement_ho,purchase_demand_raise.group_ceo_approval,purchase_demand_raise.group_head_office,purchase_demand_raise.group_matracon_admin,base.group_system"/>

    <menuitem id="menu_site_to_site_transfers"
