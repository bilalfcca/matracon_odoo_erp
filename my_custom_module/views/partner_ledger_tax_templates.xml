<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Partner Ledger: single combined Taxes column (WHT, Retention, GST, etc.) -->
    <record id="partner_ledger_taxes_column" model="account.report.column">
        <field name="name">Taxes</field>
        <field name="expression_label">taxes_amount</field>
        <field name="figure_type">monetary</field>
        <field name="blank_if_zero" eval="True"/>
        <field name="sequence">57</field>
        <field name="report_id" ref="account_reports.partner_ledger_report"/>
    </record>
</odoo>
