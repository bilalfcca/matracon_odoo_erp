<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="partner_ledger_add_tax_column"
        inherit_id="account.report_partnerledger"
        priority="30">

        <!-- Add column header after the Balance column -->
        <xpath expr="//th[contains(text(),'Balance')]" position="after">
            <th>Tax Amount</th>
        </xpath>

        <!-- Add data cell after the corresponding balance cell -->
        <!-- You need to find the correct XPath for your Odoo 19 version -->
        <xpath expr="//td[hasclass('balance')]" position="after">
            <td>
                <span t-out="line.tax_amount"/>
            </td>
        </xpath>
    </template>
</odoo>