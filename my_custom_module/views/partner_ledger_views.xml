<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="partner_ledger_add_tax_column"
        inherit_id="account.report_partnerledger"
        priority="50">

        <!-- Target the header row more precisely -->
        <xpath expr="//table[hasclass('o_account_reports_table')]//tr/th[last()]" position="after">
            <th>Tax Amount</th>
        </xpath>

        <!-- Target the data row -->
        <xpath expr="//table[hasclass('o_account_reports_table')]//tr[hasclass('o_account_reports_lines')]/td[last()]" position="after">
            <td>
                <span t-out="line.tax_amount or 0.0"/>
            </td>
        </xpath>
    </template>
</odoo>