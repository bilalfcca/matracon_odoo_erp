<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="partner_ledger_add_tax_column"
        inherit_id="account.report_partnerledger"
        priority="50">

        <!-- Add Tax column header after Balance -->
        <xpath expr="//th[contains(text(),'Balance')]" position="after">
            <th>Tax Amount</th>
        </xpath>

        <!-- Add Tax data cell -->
        <xpath expr="//td[hasclass('balance')]" position="after">
            <td t-if="line.is_tax_line">
                <span t-out="line.tax_amount"/>
            </td>
            <td t-else="">
                <span t-out="line.tax_amount or '0.00'"/>
            </td>
        </xpath>
    </template>
</odoo>