<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ── Module Category ── -->
        <record id="module_category_demand_raise" model="ir.module.category">
            <field name="name">Matracon Roles</field>
            <field name="sequence">100</field>
        </record>

        <!-- ── Privilege (Odoo 19) ── -->
        <record id="res_groups_privilege_demand_raise" model="res.groups.privilege">
            <field name="name">Matracon Roles</field>
            <field name="sequence">100</field>
            <field name="category_id" ref="module_category_demand_raise"/>
        </record>

        <!-- ══════════════════════════════════════════════════════════════
             HEAD OFFICE (HO) — cross-project visibility for all 4 HO users.
             Assign alongside the role-specific group below.
        ══════════════════════════════════════════════════════════════ -->
        <record id="group_head_office" model="res.groups">
            <field name="name">Head Office (HO)</field>
            <field name="privilege_id" ref="res_groups_privilege_demand_raise"/>
            <field name="comment">All HO users (Admin, CEO, PO, FO) — see all projects. Pair with a role group.</field>
        </record>

        <!-- ── Procurement Officer (PO) ── -->
        <record id="group_procurement_ho" model="res.groups">
            <field name="name">Procurement Officer (PO)</field>
            <field name="privilege_id" ref="res_groups_privilege_demand_raise"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_user'))]"/>
            <field name="comment">Procurement HO — reviews PRs, RFQs, comparative statements, PO preparation.</field>
        </record>

        <!-- ── CEO ── -->
        <record id="group_ceo_approval" model="res.groups">
            <field name="name">CEO</field>
            <field name="privilege_id" ref="res_groups_privilege_demand_raise"/>
            <field name="implied_ids" eval="[(4, ref('purchase.group_purchase_manager'))]"/>
            <field name="comment">CEO — final approval authority on POs and payments.</field>
        </record>

        <!-- ── Site Store — one project only (assigned via Site Project Config) ── -->
        <record id="group_site_store" model="res.groups">
            <field name="name">Site Store</field>
            <field name="privilege_id" ref="res_groups_privilege_demand_raise"/>
            <field name="implied_ids" eval="[
                (4, ref('purchase.group_purchase_user')),
                (4, ref('stock.group_stock_user')),
            ]"/>
            <field name="comment">Site Store Keepers — own project only. Assigned automatically from Site Project Configuration.</field>
        </record>
    </data>
</odoo>
