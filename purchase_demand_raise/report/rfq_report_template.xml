<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_rfq_demand_raise">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Request for Quotation</h2>
                        <p><strong>Reference:</strong> <t t-esc="o.name"/></p>
                        <p><strong>Date:</strong> <t t-esc="o.date_order" t-options='{"widget": "date"}'/></p>
                        <p t-if="o.date_approve"><strong>Order Deadline:</strong> <t t-esc="o.date_approve" t-options='{"widget": "date"}'/></p>

                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Quantity</th>
                                    <th>Unit of Measure</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.order_line" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.product_id.name"/></td>
                                        <td>
                                            <!-- RFQ cascade: recommended → requested -->
                                            <t t-if="line.x_recommended_qty > 0">
                                                <t t-esc="line.x_recommended_qty"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="line.x_requested_qty or line.product_qty"/>
                                            </t>
                                        </td>
                                        <td><t t-esc="line.product_uom_id.name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- NO pricing, NO analytic, NO internal fields on this report -->
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
