<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Final PO Report — sent to vendor after CEO final approval & dispatch -->
    <record id="action_report_final_po" model="ir.actions.report">
        <field name="name">Final Purchase Order</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">purchase_demand_raise.report_final_po_template</field>
        <field name="report_file">purchase_demand_raise.report_final_po_template</field>
        <field name="print_report_name">'Final PO - %s' % object.name</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
