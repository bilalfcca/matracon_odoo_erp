<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_pr_receipt" model="ir.ui.view">
        <field name="name">stock.picking.form.pr.receipt</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <!-- Inject PR Receipt Details group between the standard header
                 fields and the Operations notebook.
                 Only visible on incoming receipts linked to a Purchase Order. -->
            <xpath expr="//sheet/notebook" position="before">
                <group string="PR Receipt Details"
                       invisible="picking_type_code != 'incoming' or not purchase_id">
                    <group>
                        <field name="x_project_analytic_account_id"
                               string="Project"
                               readonly="1"
                               options="{'no_open': True}"/>
                        <field name="x_gate_pass_no"
                               placeholder="Enter gate pass number…"/>
                    </group>
                    <group>
                        <field name="x_weight_document"
                               widget="binary"
                               filename="x_weight_document_filename"
                               string="Weight Document (upload before validating)"/>
                        <field name="x_weight_document_filename" invisible="1"/>
                    </group>
                </group>

                <!-- QC Section -->
                <group string="Quality Control"
                       invisible="picking_type_code != 'incoming' or not purchase_id">
                    <group>
                        <field name="x_qc_state" widget="badge"
                               decoration-success="x_qc_state == 'approved'"
                               decoration-danger="x_qc_state == 'rejected'"
                               decoration-warning="x_qc_state == 'pending'"/>
                        <field name="x_qc_approved_by" readonly="1"/>
                        <field name="x_qc_approved_date" readonly="1"/>
                    </group>
                    <group>
                        <field name="x_qc_remarks"
                               placeholder="Enter inspection remarks…"/>
                    </group>
                    <div class="mt8">
                        <button name="action_qc_approve" type="object" string="QC Approve"
                                class="btn-success"
                                invisible="x_qc_state == 'approved' or state == 'done'"/>
                        <button name="action_qc_reject" type="object" string="QC Reject"
                                class="btn-danger ms-2"
                                invisible="x_qc_state == 'rejected' or state == 'done'"/>
                    </div>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
