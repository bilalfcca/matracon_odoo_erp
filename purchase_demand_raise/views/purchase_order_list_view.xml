<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════
         LIST VIEW — PR / PO with approval status columns
         ════════════════════════════════════════════════════════ -->
    <record id="view_purchase_order_list_demand_raise" model="ir.ui.view">
        <field name="name">purchase.order.list.demand.raise</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">

            <!-- Hide standard Buyer column (replaced by Raised By) -->
            <field name="user_id" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>

            <!-- Hide standard Status column (we use x_pr_state) -->
            <field name="state" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>

            <!-- Hide monetary Total column from Site Store users -->
            <field name="amount_total" position="attributes">
                <attribute name="groups">!purchase_demand_raise.group_site_store</attribute>
            </field>

            <!-- Inject custom columns after Reference (name) -->
            <field name="name" position="after">
                <field name="x_initiator_id" string="Raised By" optional="show"/>
                <field name="x_project_analytic_account_id" string="Project" optional="show"/>
                <field name="x_category_id" string="Category" optional="show"/>
                <field name="x_pr_state" string="PR Status"
                       widget="badge"
                       decoration-info="x_pr_state == 'draft'"
                       decoration-warning="x_pr_state in ('submitted', 'rfq_phase', 'ceo_final')"
                       decoration-success="x_pr_state == 'po_locked'"
                       decoration-danger="x_pr_state in ('rejected', 'cancelled')"
                       optional="show"/>
                <field name="x_ho_status" string="HO Status"
                       widget="badge"
                       decoration-warning="x_ho_status == 'pending'"
                       decoration-success="x_ho_status == 'approved'"
                       decoration-danger="x_ho_status == 'rejected'"
                       optional="show"/>
                <field name="x_ceo_status" string="CEO Status"
                       widget="badge"
                       decoration-warning="x_ceo_status == 'pending'"
                       decoration-success="x_ceo_status == 'approved'"
                       decoration-danger="x_ceo_status == 'rejected'"
                       optional="show"/>
            </field>

        </field>
    </record>

    <!-- Also update the KPI list view -->
    <record id="view_purchase_order_kpis_list_demand_raise" model="ir.ui.view">
        <field name="name">purchase.order.kpis.list.demand.raise</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">

            <field name="user_id" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <field name="state" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <!-- Hide monetary Total from Site Store users -->
            <field name="amount_total" position="attributes">
                <attribute name="groups">!purchase_demand_raise.group_site_store</attribute>
            </field>

            <field name="name" position="after">
                <field name="x_initiator_id" string="Raised By" optional="show"/>
                <field name="x_project_analytic_account_id" string="Project" optional="show"/>
                <field name="x_category_id" string="Category" optional="show"/>
                <field name="x_pr_state" string="PR Status"
                       widget="badge"
                       decoration-info="x_pr_state == 'draft'"
                       decoration-warning="x_pr_state in ('submitted', 'rfq_phase', 'ceo_final')"
                       decoration-success="x_pr_state == 'po_locked'"
                       decoration-danger="x_pr_state in ('rejected', 'cancelled')"
                       optional="show"/>
                <field name="x_ho_status" string="HO Status"
                       widget="badge"
                       decoration-warning="x_ho_status == 'pending'"
                       decoration-success="x_ho_status == 'approved'"
                       decoration-danger="x_ho_status == 'rejected'"
                       optional="show"/>
                <field name="x_ceo_status" string="CEO Status"
                       widget="badge"
                       decoration-warning="x_ceo_status == 'pending'"
                       decoration-success="x_ceo_status == 'approved'"
                       decoration-danger="x_ceo_status == 'rejected'"
                       optional="show"/>
            </field>

        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════
         SEARCH VIEW — PR filters, group-by, and search panel
         ════════════════════════════════════════════════════════ -->
    <record id="view_purchase_rfq_search_demand_raise" model="ir.ui.view">
        <field name="name">purchase.rfq.search.demand.raise</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">

            <!-- Add PR search fields and filters at the top of the search view -->
            <xpath expr="//search" position="inside">

                <!-- Extra search fields -->
                <field name="x_initiator_id" string="Raised By"/>
                <field name="x_project_analytic_account_id" string="Project"/>
                <field name="x_category_id" string="Category"/>

                <separator/>

                <!-- Approval status filters -->
                <filter name="pending_ho_approval"
                        string="Pending HO Approval"
                        domain="[('x_ho_status', '=', 'pending'), ('x_pr_state', 'not in', ['draft', 'rejected', 'cancelled'])]"/>

                <filter name="pending_ceo_approval"
                        string="Pending CEO Approval"
                        domain="[('x_ceo_status', '=', 'pending'), ('x_pr_state', 'not in', ['draft', 'rejected', 'cancelled'])]"/>

                <filter name="awaiting_joint_approval"
                        string="Awaiting Joint Approval"
                        domain="[('x_pr_state', '=', 'submitted')]"/>

                <filter name="rfq_phase"
                        string="In RFQ Phase"
                        domain="[('x_pr_state', '=', 'rfq_phase')]"/>

                <filter name="ceo_final_review"
                        string="Pending CEO Final"
                        domain="[('x_pr_state', '=', 'ceo_final')]"/>

                <filter name="po_locked"
                        string="PO Locked — Ready to Dispatch"
                        domain="[('x_pr_state', '=', 'po_locked')]"/>

                <filter name="rejected"
                        string="Rejected"
                        domain="[('x_pr_state', '=', 'rejected')]"/>

                <separator/>

                <!-- Group-by options -->
                <filter name="group_pr_state"
                        string="Group by PR Status"
                        context="{'group_by': 'x_pr_state'}"/>
                <filter name="group_project"
                        string="Group by Project"
                        context="{'group_by': 'x_project_analytic_account_id'}"/>
                <filter name="group_category"
                        string="Group by Category"
                        context="{'group_by': 'x_category_id'}"/>
                <filter name="group_initiator"
                        string="Group by Raised By"
                        context="{'group_by': 'x_initiator_id'}"/>

            </xpath>
        </field>
    </record>


</odoo>
