<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_procurement_ho_dashboard_form" model="ir.ui.view">
        <field name="name">x.procurement.ho.dashboard.form</field>
        <field name="model">x.procurement.ho.dashboard</field>
        <field name="arch" type="xml">
            <form string="Procurement Operations Overview" create="false" delete="false">
                <header>
                    <button name="action_refresh" type="object" string="Refresh"
                            class="btn-secondary" icon="fa-refresh"/>
                    <!-- Hidden domain helper — populated during refresh -->
                    <field name="available_project_ids" invisible="1"/>
                    <!-- Inline filters in the header bar -->
                    <field name="filter_project_id" nolabel="1"
                           placeholder="All Projects"
                           options="{'no_create': True, 'no_open': True}"
                           domain="[('id', 'in', available_project_ids)]"
                           class="o_field_widget ms-3" style="min-width:130px;"/>
                    <field name="filter_contact_id" nolabel="1"
                           placeholder="Vendor / Subcontractor"
                           options="{'no_create': True, 'no_open': True}"
                           class="o_field_widget ms-2" style="min-width:150px;"/>
                    <field name="filter_category_id" nolabel="1"
                           placeholder="Category"
                           options="{'no_create': True, 'no_open': True}"
                           class="o_field_widget ms-2" style="min-width:100px;"/>
                    <field name="filter_pr_state" nolabel="1"
                           placeholder="PR Status"
                           class="o_field_widget ms-2" style="min-width:110px;"/>
                    <field name="filter_period_days" nolabel="1"
                           placeholder="Date Range"
                           class="o_field_widget ms-2" style="min-width:110px;"/>
                    <field name="filter_section" nolabel="1"
                           placeholder="Focus"
                           class="o_field_widget ms-2" style="min-width:110px;"/>
                    <button name="action_apply_filters" type="object"
                            string="Apply" class="btn-primary ms-2" icon="fa-check"/>
                </header>
                <sheet>

                    <!-- ── Title ────────────────────────────────────────────── -->
                    <div class="oe_title mb-3">
                        <h1><field name="name" readonly="1" class="oe_inline"/></h1>
                        <p class="text-muted mb-0">
                            <field name="user_name" readonly="1" class="oe_inline"/>
                            — Procurement Officer
                        </p>
                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         KPI CARDS — Top row (3 cards)
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-4">

                        <div class="col-12 col-sm-4">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-4">
                                    <small class="text-muted text-uppercase fw-bold"
                                           style="font-size:0.7rem; letter-spacing:0.06em;">Pending Site Demands</small>
                                    <div class="fw-bold text-danger mt-2 mb-1"
                                         style="font-size:2.6rem; line-height:1.1;">
                                        <field name="pending_review_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <small class="text-muted">Awaiting HO Review</small>
                                        <button name="action_open_pending_review" type="object"
                                                string="Review" class="btn btn-sm btn-outline-danger"
                                                style="font-size:0.72rem; padding:2px 8px;"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-4">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-4">
                                    <small class="text-muted text-uppercase fw-bold"
                                           style="font-size:0.7rem; letter-spacing:0.06em;">Active CS / RFQ</small>
                                    <div class="fw-bold mt-2 mb-1"
                                         style="font-size:2.6rem; line-height:1.1; color:#fd7e14;">
                                        <field name="active_cs_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between">
                                        <small class="text-muted">Comparative Statements</small>
                                        <button name="action_open_active_cs" type="object"
                                                string="View CS" class="btn btn-sm btn-outline-warning"
                                                style="font-size:0.72rem; padding:2px 8px;"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-sm-4">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-body py-3 px-4">
                                    <small class="text-muted text-uppercase fw-bold"
                                           style="font-size:0.7rem; letter-spacing:0.06em;">Confirmed Orders</small>
                                    <div class="fw-bold text-info mt-2 mb-1"
                                         style="font-size:2.6rem; line-height:1.1;">
                                        <field name="confirmed_orders_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <small class="text-muted">Active Purchase Orders</small>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         ROW 2: Pending CEO Approvals (left) + Orders Quick View (right)
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-3">

                        <!-- Left: Pending CEO Approvals -->
                        <div class="col-12 col-xl-7">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header d-flex justify-content-between align-items-center py-2 px-4"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        <i class="fa fa-gavel me-2 text-warning" title="CEO"/>
                                        Pending CEO Approvals
                                        <span class="badge text-bg-warning ms-2">
                                            <field name="ceo_pending_count" nolabel="1" readonly="1" class="oe_inline"/>
                                        </span>
                                    </strong>
                                    <button name="action_open_ceo_pending" type="object"
                                            string="View All" class="btn btn-sm btn-outline-warning"
                                            style="font-size:0.72rem;"/>
                                </div>
                                <div class="card-body p-0">
                                    <field name="ceo_pending_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false"
                                              decoration-warning="x_pr_state == 'ceo_final'">
                                            <field name="name" string="Requisition"/>
                                            <field name="x_category_id" string="Category"/>
                                            <field name="x_project_analytic_account_id" string="Project"/>
                                            <field name="partner_id" string="Vendor"/>
                                            <field name="amount_total" string="Value" widget="monetary"/>
                                            <field name="x_ho_status" string="HO Status" widget="badge"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                        <!-- Right: Dispatch Quick View -->
                        <div class="col-12 col-xl-5">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header d-flex justify-content-between align-items-center py-2 px-4"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        <i class="fa fa-paper-plane me-2 text-success" title="Dispatch"/>
                                        Ready to Dispatch
                                        <span class="badge text-bg-success ms-2">
                                            <field name="ready_dispatch_count" nolabel="1" readonly="1" class="oe_inline"/>
                                        </span>
                                    </strong>
                                    <button name="action_open_ready_dispatch" type="object"
                                            string="Dispatch Now" class="btn btn-sm btn-outline-success"
                                            style="font-size:0.72rem;"/>
                                </div>
                                <div class="card-body p-0">
                                    <field name="ready_dispatch_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false"
                                              decoration-success="x_pr_state == 'po_locked'">
                                            <field name="name" string="Reference"/>
                                            <field name="partner_id" string="Vendor"/>
                                            <field name="x_project_analytic_account_id" string="Project"/>
                                            <field name="date_order" string="Date"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         ROW 3: Critical Demands (left) + Pending HO Review (right)
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-3"
                         invisible="filter_section not in ('all', 'critical', 'pending_review')">

                        <div class="col-12 col-xl-6"
                             invisible="filter_section not in ('all', 'critical')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-4 d-flex justify-content-between"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        <i class="fa fa-exclamation-triangle me-2 text-danger" title="Critical"/>
                                        Critical Site Demands
                                    </strong>
                                    <button name="action_open_critical_demands" type="object"
                                            string="View All" class="btn btn-sm btn-outline-danger"
                                            style="font-size:0.72rem;"/>
                                </div>
                                <div class="card-body p-0">
                                    <field name="critical_demand_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false"
                                              decoration-danger="x_ho_status == 'pending'">
                                            <field name="name" string="Requisition"/>
                                            <field name="x_project_analytic_account_id" string="Site"/>
                                            <field name="x_category_id" string="Category"/>
                                            <field name="date_order" string="Raised On"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-6"
                             invisible="filter_section not in ('all', 'pending_review')">
                            <div class="card border-0 h-100" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-4 d-flex justify-content-between"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        <i class="fa fa-inbox me-2 text-primary" title="Pending Review"/>
                                        Pending HO Review
                                    </strong>
                                </div>
                                <div class="card-body p-0">
                                    <field name="pending_review_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false"
                                              decoration-warning="x_ho_status == 'pending'">
                                            <field name="name" string="Reference"/>
                                            <field name="x_project_analytic_account_id" string="Project"/>
                                            <field name="x_category_id" string="Category"/>
                                            <field name="x_initiator_id" string="Raised By"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                            <field name="x_ho_status" string="HO Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         ROW 4: Active CS + Recently Dispatched
                    ══════════════════════════════════════════════════════ -->
                    <div class="row g-3 mb-3"
                         invisible="filter_section not in ('all', 'active_cs', 'dispatched')">

                        <div class="col-12 col-xl-6"
                             invisible="filter_section not in ('all', 'active_cs')">
                            <div class="card border-0" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-4"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">Active CS / RFQ</strong>
                                </div>
                                <div class="card-body p-0">
                                    <field name="active_cs_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false">
                                            <field name="name" string="Reference"/>
                                            <field name="x_project_analytic_account_id" string="Project"/>
                                            <field name="partner_id" string="Vendor"/>
                                            <field name="x_has_tender_alternatives" string="Alternatives"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-6"
                             invisible="filter_section not in ('all', 'dispatched')">
                            <div class="card border-0" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                                <div class="card-header py-2 px-4 d-flex justify-content-between"
                                     style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                                    <strong style="font-size:0.9rem;">
                                        Dispatched (MTD)
                                        <span class="badge text-bg-primary ms-2">
                                            <field name="dispatched_mtd_count" nolabel="1" readonly="1" class="oe_inline"/>
                                        </span>
                                    </strong>
                                    <button name="action_open_dispatched" type="object"
                                            string="View All" class="btn btn-sm btn-outline-primary"
                                            style="font-size:0.72rem;"/>
                                </div>
                                <div class="card-body p-0">
                                    <field name="recent_dispatched_ids" nolabel="1" readonly="1">
                                        <list create="false" delete="false" edit="false">
                                            <field name="name" string="Reference"/>
                                            <field name="partner_id" string="Vendor"/>
                                            <field name="x_project_analytic_account_id" string="Project"/>
                                            <field name="write_date" string="Dispatched On"/>
                                            <field name="x_pr_state" string="Status" widget="badge"/>
                                        </list>
                                    </field>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         ROW 5: Recent Purchase Orders (full width)
                    ══════════════════════════════════════════════════════ -->
                    <div class="card border-0 mb-3" style="box-shadow:0 1px 6px rgba(0,0,0,.12); border-radius:8px;">
                        <div class="card-header py-2 px-4"
                             style="background:transparent; border-bottom:1px solid rgba(0,0,0,.07);">
                            <strong style="font-size:0.9rem;">Recent Purchase Orders</strong>
                        </div>
                        <div class="card-body p-0">
                            <field name="recent_po_ids" nolabel="1" readonly="1">
                                <list create="false" delete="false" edit="false"
                                      decoration-success="state in ('purchase', 'done')">
                                    <field name="name" string="PO"/>
                                    <field name="partner_id" string="Vendor"/>
                                    <field name="x_project_analytic_account_id" string="Project"/>
                                    <field name="amount_total" string="Value" widget="monetary"/>
                                    <field name="state" string="Odoo Status" widget="badge"/>
                                    <field name="x_pr_state" string="PR Status" widget="badge"/>
                                </list>
                            </field>
                        </div>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_procurement_ho_dashboard" model="ir.actions.server">
        <field name="name">Procurement HO Dashboard</field>
        <field name="model_id" ref="model_x_procurement_ho_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
