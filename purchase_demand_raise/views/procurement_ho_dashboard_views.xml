<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_procurement_ho_dashboard_form" model="ir.ui.view">
        <field name="name">x.procurement.ho.dashboard.form</field>
        <field name="model">x.procurement.ho.dashboard</field>
        <field name="arch" type="xml">
            <form string="Procurement Operations Overview" create="false" delete="false">
                <header>
                    <button name="action_refresh" type="object" string="Refresh"
                            class="btn-secondary" icon="fa-refresh"/>
                </header>
                <sheet>

                    <!-- ── Dashboard Title ──────────────────────────────────── -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" class="oe_inline"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="user_name" readonly="1" class="oe_inline"/>
                            — Procurement Officer
                        </h3>
                    </div>

                    <!-- ── Filters Card ──────────────────────────────────────── -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h6 class="card-title text-muted text-uppercase mb-3"
                                style="font-size: 0.75rem; letter-spacing: 0.08em;">
                                <i class="fa fa-filter me-1" title="Filters"/> Dashboard Filters
                            </h6>
                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Project</label>
                                    <field name="filter_project_id" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Category</label>
                                    <field name="filter_category_id" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">PR Status</label>
                                    <field name="filter_pr_state" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Date Range</label>
                                    <field name="filter_period_days" nolabel="1"/>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label class="col-form-label col-form-label-sm fw-bold">Focus</label>
                                    <field name="filter_section" nolabel="1"/>
                                </div>
                            </div>
                            <div class="mt-3">
                                <button name="action_apply_filters" type="object"
                                        string="Apply Filters" class="btn btn-primary btn-sm"/>
                            </div>
                        </div>
                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         KPI CARDS — ROW 1 (Demand Pipeline)
                    ══════════════════════════════════════════════════════ -->
                    <div class="mb-1">
                        <p class="text-muted text-uppercase fw-bold mb-2"
                           style="font-size: 0.75rem; letter-spacing: 0.08em;">
                            Demand Pipeline
                        </p>
                    </div>
                    <div class="row g-3 mb-4">

                        <!-- Pending Site Demands -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-danger mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="pending_review_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Pending Site Demands</div>
                                    <div class="mt-2">
                                        <button name="action_open_pending_review" type="object"
                                                string="Review" class="btn btn-sm btn-outline-danger"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pending CEO Approval -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold mb-1" style="font-size: 2.5rem; line-height: 1.1; color: #fd7e14;">
                                        <field name="ceo_pending_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Pending CEO Approval</div>
                                    <div class="mt-2">
                                        <button name="action_open_ceo_pending" type="object"
                                                string="View" class="btn btn-sm btn-outline-warning"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Active CS / RFQ -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-warning mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="active_cs_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Active CS / RFQ</div>
                                    <div class="mt-2">
                                        <button name="action_open_active_cs" type="object"
                                                string="View" class="btn btn-sm btn-outline-warning"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         KPI CARDS — ROW 2 (Orders & Dispatch)
                    ══════════════════════════════════════════════════════ -->
                    <div class="mb-1">
                        <p class="text-muted text-uppercase fw-bold mb-2"
                           style="font-size: 0.75rem; letter-spacing: 0.08em;">
                            Orders &amp; Dispatch
                        </p>
                    </div>
                    <div class="row g-3 mb-4">

                        <!-- Ready to Dispatch -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-success mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="ready_dispatch_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Ready to Dispatch</div>
                                    <div class="mt-2">
                                        <button name="action_open_ready_dispatch" type="object"
                                                string="Dispatch" class="btn btn-sm btn-outline-success"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Dispatched MTD -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-primary mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="dispatched_mtd_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Dispatched (MTD)</div>
                                    <div class="mt-2">
                                        <button name="action_open_dispatched" type="object"
                                                string="View" class="btn btn-sm btn-outline-primary"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Confirmed Orders -->
                        <div class="col-12 col-sm-6 col-xl-4">
                            <div class="card border-0 shadow-sm h-100 text-center">
                                <div class="card-body py-4">
                                    <div class="fw-bold text-info mb-1" style="font-size: 2.5rem; line-height: 1.1;">
                                        <field name="confirmed_orders_count" nolabel="1" readonly="1" class="oe_inline"/>
                                    </div>
                                    <div class="text-muted" style="font-size: 0.85rem;">Confirmed Orders</div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- ══════════════════════════════════════════════════════
                         DETAIL TABLES
                    ══════════════════════════════════════════════════════ -->

                    <group string="Pending CEO Approvals"
                           invisible="filter_section not in ('all', 'ceo_approval')">
                        <field name="ceo_pending_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-warning="x_pr_state == 'ceo_final'">
                                <field name="name" string="Requisition"/>
                                <field name="x_category_id" string="Category"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="amount_total" string="Value"/>
                                <field name="x_ho_status" string="HO Status" widget="badge"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Critical Site Demands"
                           invisible="filter_section not in ('all', 'critical')">
                        <button name="action_open_critical_demands" type="object"
                                string="View All Critical" class="btn-link"/>
                        <field name="critical_demand_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-danger="x_ho_status == 'pending'">
                                <field name="name" string="Requisition"/>
                                <field name="x_project_analytic_account_id" string="Site"/>
                                <field name="x_category_id" string="Category"/>
                                <field name="date_order" string="Raised On"/>
                                <field name="x_initiator_id" string="Requester"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Pending HO Review"
                           invisible="filter_section not in ('all', 'pending_review')">
                        <field name="pending_review_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-warning="x_ho_status == 'pending'">
                                <field name="name" string="Reference"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="x_category_id" string="Category"/>
                                <field name="x_initiator_id" string="Raised By"/>
                                <field name="date_order" string="Date"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                                <field name="x_ho_status" string="HO Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Active CS / RFQ"
                           invisible="filter_section not in ('all', 'active_cs')">
                        <field name="active_cs_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name" string="Reference"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="x_initiator_id" string="Raised By"/>
                                <field name="x_has_tender_alternatives" string="Alternatives"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Ready to Dispatch"
                           invisible="filter_section not in ('all', 'ready_dispatch')">
                        <field name="ready_dispatch_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-success="x_pr_state == 'po_locked'">
                                <field name="name" string="Reference"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="date_order" string="Date"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Recently Dispatched"
                           invisible="filter_section not in ('all', 'dispatched')">
                        <field name="recent_dispatched_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="name" string="Reference"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="write_date" string="Dispatched On"/>
                                <field name="x_pr_state" string="Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                    <group string="Activity Log"
                           invisible="filter_section not in ('all',)">
                        <field name="activity_message_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false">
                                <field name="date" string="When"/>
                                <field name="author_id" string="User"/>
                                <field name="record_name" string="Document"/>
                                <field name="body" string="Message" widget="html"/>
                            </list>
                        </field>
                    </group>

                    <group string="Recent Purchase Orders">
                        <field name="recent_po_ids" nolabel="1" readonly="1">
                            <list create="false" delete="false" edit="false"
                                  decoration-success="state in ('purchase', 'done')">
                                <field name="name" string="PO"/>
                                <field name="partner_id" string="Vendor"/>
                                <field name="x_project_analytic_account_id" string="Project"/>
                                <field name="amount_total" string="Value"/>
                                <field name="state" string="Odoo Status" widget="badge"/>
                                <field name="x_pr_state" string="PR Status" widget="badge"/>
                            </list>
                        </field>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_procurement_ho_dashboard" model="ir.actions.server">
        <field name="name">Procurement HO Dashboard</field>
        <field name="model_id" ref="model_x_procurement_ho_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
